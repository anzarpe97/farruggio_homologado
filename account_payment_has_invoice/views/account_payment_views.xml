<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit the payment list view to add the has_invoice checkbox -->
    <record id="view_account_payment_tree_inherit_has_invoice" model="ir.ui.view">
        <field name="name">account.payment.tree.has.invoice</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//tree/field[@name='partner_id']" position="before">
                <field name="has_invoice" string="Factura" readonly="1" widget="boolean_toggle"/>
            </xpath>
        </field>
    </record>
</odoo>
