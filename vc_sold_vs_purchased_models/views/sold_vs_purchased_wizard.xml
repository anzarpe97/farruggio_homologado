<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_sold_vs_purchased_wizard" model="ir.ui.view">
        <field name="name">sold.vs.purchased.wizard.form</field>
        <field name="model">sold.vs.purchased.wizard</field>
        <field name="arch" type="xml">
            <form string="Reporte: Vendido vs Comprado">
                <group>
                    <group>
                        <field name="start_date"/>
                        <field name="end_date"/>
                        <field name="user_id" options="{'no_create': True}"/>
                        <field name="partner_id" options="{'no_create': True}"/>
                        <field name="include_purchase"/>
                        <field name="filter_by_material" attrs="{'invisible': [('include_purchase', '=', False)]}"/>
                           <field name="filter_by_material" invisible="1"/>
                    </group>
                </group>
                <footer>
                    <button string="Exportar XLSX y Recargar"
                            name="action_export_xlsx_and_reload"
                            type="object"
                            class="btn-primary"
                            help="Descarga el reporte y recarga el wizard para hacer cambios rápidamente"/>
                    <button string="Exportar XLSX"
                            name="action_export_xlsx"
                            type="object"
                            class="btn-secondary"/>
                    <button string="Cancelar" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_sold_vs_purchased_wizard" model="ir.actions.act_window">
        <field name="name">Vendido vs Comprado</field>
        <field name="res_model">sold.vs.purchased.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_sold_vs_purchased_root"
              name="Vendido vs Comprado"
              parent="account.menu_finance_reports"
              action="action_sold_vs_purchased_wizard"
              sequence="95"/>
</odoo>
