<odoo>
    <record id="view_picking_form_inherit_note" model="ir.ui.view">
        <field name="name">stock.picking.form.note.inherit</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook/page[@name='note']" position="after">
                <page string="Notas del Pedido">
                    <field name="sale_note_lines" readonly="1"/>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
