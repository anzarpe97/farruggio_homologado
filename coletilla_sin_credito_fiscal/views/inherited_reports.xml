<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Coletilla en Pedido de Venta -->
    <template id="report_saleorder_document_inherit_credit_note" inherit_id="sale.report_saleorder_document">
        <xpath expr="//div[p[@t-field='doc.note']]" position="after">
            <p style="margin-top: 420px; text-align: center; font-weight: bold;">
                DOCUMENTO SIN DERECHO A CRÉDITO FISCAL
            </p>
        </xpath>
    </template>

    <!-- Coletilla en Orden de Entrega -->
    <template id="report_delivery_document_inherit_credit_note" inherit_id="stock.report_delivery_document">
        <xpath expr="//div[@class='page']" position="inside">
            <p style="margin-top: 50px; text-align: center; font-weight: bold; font-size: 12px;">
                DOCUMENTO SIN DERECHO A CRÉDITO FISCAL
            </p>
        </xpath>
    </template>

    <!-- Coletilla en Orden de Compra que se repite en cada página -->
    <template id="report_purchaseorder_document_custom" inherit_id="purchase.report_purchaseorder_document">
        <xpath expr="//div[@class='page']" position="inside">
            <div style="margin-top: 200px; text-align: center; font-weight: bold;">
                DOCUMENTO NO FISCAL
            </div>
        </xpath>
    </template>

    <!-- Coletilla en Orden de Compra que se repite en cada página -->
    <template id="report_purchaseorder_document_custom" inherit_id="purchase.report_purchasequotation_document">
        <xpath expr="//div[@class='page']" position="inside">
            <div style="margin-top: 200px; text-align: center; font-weight: bold;">
                DOCUMENTO NO FISCAL
            </div>
        </xpath>
    </template>


    <template id="report_delivery_document_title_inherit" inherit_id="stock.report_delivery_document">
        <xpath expr="//div[@class='page']/h2" position="before">
            <h1 style="text-align: left; font-size: 32px; margin-bottom: 5px; margin-top: 0;">
                ORDEN DE ENTREGA
            </h1>
        </xpath>
    </template>

</odoo>
