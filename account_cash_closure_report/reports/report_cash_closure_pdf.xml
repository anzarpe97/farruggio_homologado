<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="report_cash_closure_pdf_template">
        <t t-call="web.html_container">
            <style>
                /* clase para eliminar cualquier borde heredado en pdf */
                .no-border, .no-border th, .no-border td {
                    border: none !important;
                    box-shadow: none !important;
                    background: transparent !important;
                }
            </style>
            <t t-foreach="docs" t-as="doc">
                <t t-set="company" t-value="doc.env.company"/>
                <t t-set="totals" t-value="totals or {}"/>
                <t t-set="lines" t-value="lines or []"/>
                <t t-call="web.external_layout">
                    <t t-if="'caja' in selected_section_codes or not selected_section_codes">
                    <div class="page" style="font-size:10px;">
                        <div style="text-align:center; font-weight:bold; font-size:16px;">
                            <t t-esc="company.name or ''"/>
                        </div>
                        <div style="text-align:center; font-size:12px;">
                            <t t-esc="company.street or ''"/>
                            <t t-if="company.street2">, <t t-esc="company.street2"/></t>
                            <t t-if="company.city">, <t t-esc="company.city"/></t>
                            <t t-if="company.state_id">, <t t-esc="company.state_id.name"/></t>
                        </div>
                        <div style="text-align:center; font-size:12px;">
                            <strong>RIF:</strong> <t t-esc="company.vat or ''"/>
                        </div>
                        <div style="text-align:center; font-size:14px; font-weight:bold; margin-top:10px;">
                            Reporte de Cierre de Caja
                        </div>
                        <div style="text-align:right; font-size:10px; margin-top:5px;">
                            <strong>Página :</strong> <span>1 de 1</span>
                            <br/>
                            <t t-esc="doc.create_date and doc.create_date.strftime('%d/%m/%Y %H:%M:%S') or ''"/> <!-- Fecha de generación -->
                        </div>
                        <div style="text-align:left; font-size:11px; margin-top:10px;">
                            <strong>Ventas Desde :</strong>
                            <t t-esc="doc.start_date or ''"/> Hora : 07:00 AM
                            <strong>Hasta el :</strong>
                            <t t-esc="doc.end_date or ''"/> Hora : 11:59 PM
                        </div>
                        <table style="width:100%; border-collapse:collapse; margin-top:10px; font-size:10px;">
                            <thead>
                                <tr style="background:#eee;">
                                    <th style="border:1px solid #888;">Fecha-Hora</th>
                                    <th style="border:1px solid #888;">Número</th>
                                    <th style="border:1px solid #888;">Cliente</th>
                                    <th style="border:1px solid #888; text-align:right;">Total Operación</th>
                                    <th style="border:1px solid #888; text-align:right;">Contado</th>
                                    <th style="border:1px solid #888; text-align:right;">Crédito</th>
                                    <th style="border:1px solid #888; text-align:right;">Impuestos</th>
                                    <th style="border:1px solid #888; text-align:right;">Efectivo</th>
                                    <th style="border:1px solid #888; text-align:right;">Transferencia</th>
                                    <th style="border:1px solid #888; text-align:right;">Instru. de Pag.</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="lines" t-as="l">
                                    <tr>
                                        <td style="border:1px solid #888; text-align:center;">
                                            <t t-esc="l.get('fecha_hora') or ''"/>
                                        </td>
                                        <td style="border:1px solid #888; text-align:center;">
                                            <t t-esc="l.get('numero') or ''"/>
                                        </td>
                                        <td style="border:1px solid #888;">
                                            <t t-esc="l.get('cliente') or ''"/>
                                        </td>
                                        <td style="border:1px solid #888; text-align:right;">
                                            <t t-esc="'%0.2f' % (l.get('total_oper') or 0.0)"/>
                                        </td>
                                        <td style="border:1px solid #888; text-align:right;">
                                            <t t-esc="'%0.2f' % (l.get('contado') or 0.0)"/>
                                        </td>
                                        <td style="border:1px solid #888; text-align:right;">
                                            <t t-esc="'%0.2f' % (l.get('credito') or 0.0)"/>
                                        </td>
                                        <td style="border:1px solid #888; text-align:right;">
                                            <t t-esc="'%0.2f' % (l.get('impuesto') or 0.0)"/>
                                        </td>
                                        <td style="border:1px solid #888; text-align:right;">
                                            <t t-esc="'%0.2f' % (l.get('efectivo') or 0.0)"/>
                                        </td>
                                        <td style="border:1px solid #888; text-align:right;">
                                            <t t-esc="'%0.2f' % (l.get('transferencia') or 0.0)"/>
                                        </td>
                                        <td style="border:1px solid #888; text-align:right;">
                                            <t t-esc="'%0.2f' % (l.get('instru_pag') or 0.0)"/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                            <tfoot>
                                <tr style="background:#eee; font-weight:bold;">
                                    <td colspan="3" style="border:1px solid #888; text-align:right;">Sub-Totales:</td>
                                    <td style="border:1px solid #888; text-align:right;">
                                        <t t-esc="'%0.2f' % (totals.get('total_oper') or 0.0)"/>
                                    </td>
                                    <td style="border:1px solid #888; text-align:right;">
                                        <t t-esc="'%0.2f' % (totals.get('contado') or 0.0)"/>
                                    </td>
                                    <td style="border:1px solid #888; text-align:right;">
                                        <t t-esc="'%0.2f' % (totals.get('credito') or 0.0)"/>
                                    </td>
                                    <td style="border:1px solid #888; text-align:right;">
                                        <t t-esc="'%0.2f' % (totals.get('impuesto') or 0.0)"/>
                                    </td>
                                    <td style="border:1px solid #888; text-align:right;">
                                        <t t-esc="'%0.2f' % (totals.get('efectivo') or 0.0)"/>
                                    </td>
                                    <td style="border:1px solid #888; text-align:right;">
                                        <t t-esc="'%0.2f' % (totals.get('transferencia') or 0.0)"/>
                                    </td>
                                    <td style="border:1px solid #888; text-align:right;">
                                        <t t-esc="'%0.2f' % (totals.get('instru_pag') or 0.0)"/>
                                    </td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                    </t>
                    <!-- Nueva página: Resumen de cobros -->
                    <t t-if="'cobros' in selected_section_codes">
                    <div class="page" style="font-size:12px; page-break-before:always;">
                        <div style="text-align:center; font-weight:bold; font-size:16px;">
                            <t t-esc="company.name or ''"/>
                        </div>
                        <div style="text-align:center; font-size:14px; font-weight:bold; margin-top:10px;">
                            Resumen de cobros
                        </div>
                        <div style="text-align:left; font-size:11px; margin-top:10px;">
                            <strong>Periodo :</strong>
                            <t t-esc="doc.start_date or ''"/> a <t t-esc="doc.end_date or ''"/>
                        </div>
                        <table style="width:100%; border-collapse:collapse; margin-top:10px; font-size:10px;">
                            <thead>
                                <tr style="background:#eee;">
                                    <th style="border:1px solid #888;">Fecha</th>
                                    <th style="border:1px solid #888;">Vendedor</th>
                                    <th style="border:1px solid #888;">Cliente</th>
                                    <th style="border:1px solid #888;">Referencia</th>
                                    <th style="border:1px solid #888;">Detalle</th>
                                    <th style="border:1px solid #888; text-align:right;">Monto</th>
                                    <th style="border:1px solid #888; text-align:right;">Retención</th>
                                    <th style="border:1px solid #888; text-align:right;">Total ingreso</th>
                                    <th style="border:1px solid #888; text-align:right;">Efectivo</th>
                                    <th style="border:1px solid #888; text-align:right;">Transferencia</th>
                                    <th style="border:1px solid #888; text-align:right;">Instrumento de pago</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="cobros_lines or []" t-as="l">
                                    <tr>
                                        <td style="border:1px solid #888; text-align:center;">
                                            <t t-esc="l.get('fecha') and l.get('fecha').strftime('%d/%m/%Y') or ''"/>
                                        </td>
                                        <td style="border:1px solid #888;">
                                            <t t-esc="l.get('vendedor') or ''"/>
                                        </td>
                                        <td style="border:1px solid #888;">
                                            <t t-esc="l.get('cliente') or ''"/>
                                        </td>
                                        <td style="border:1px solid #888;">
                                            <t t-esc="l.get('referencia') or ''"/>
                                        </td>
                                        <td style="border:1px solid #888;">
                                            <t t-esc="l.get('detalle') or ''"/>
                                        </td>
                                        <td style="border:1px solid #888; text-align:right;">
                                            <t t-esc="'%0.2f' % (l.get('monto') or 0.0)"/>
                                        </td>
                                        <td style="border:1px solid #888; text-align:right;">
                                            <t t-esc="'%0.2f' % (l.get('retencion') or 0.0)"/>
                                        </td>
                                        <td style="border:1px solid #888; text-align:right;">
                                            <t t-esc="'%0.2f' % (l.get('total_ingreso') or 0.0)"/>
                                        </td>
                                        <td style="border:1px solid #888; text-align:right;">
                                            <t t-esc="'%0.2f' % (l.get('efectivo') or 0.0)"/>
                                        </td>
                                        <td style="border:1px solid #888; text-align:right;">
                                            <t t-esc="'%0.2f' % (l.get('transferencia') or 0.0)"/>
                                        </td>
                                        <td style="border:1px solid #888; text-align:right;">
                                            <t t-esc="'%0.2f' % (l.get('instru_pag') or 0.0)"/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                            <tfoot>
                                <tr style="background:#eee; font-weight:bold;">
                                    <td colspan="5" style="border:1px solid #888; text-align:right;">Totales:</td>
                                    <td style="border:1px solid #888; text-align:right;">
                                        <t t-esc="'%0.2f' % (cobros_totals.get('monto') or 0.0)"/>
                                    </td>
                                    <td style="border:1px solid #888; text-align:right;">
                                        <t t-esc="'%0.2f' % (cobros_totals.get('retencion') or 0.0)"/>
                                    </td>
                                    <td style="border:1px solid #888; text-align:right;">
                                        <t t-esc="'%0.2f' % (cobros_totals.get('total_ingreso') or 0.0)"/>
                                    </td>
                                    <td style="border:1px solid #888; text-align:right;">
                                        <t t-esc="'%0.2f' % (cobros_totals.get('efectivo') or 0.0)"/>
                                    </td>
                                    <td style="border:1px solid #888; text-align:right;">
                                        <t t-esc="'%0.2f' % (cobros_totals.get('transferencia') or 0.0)"/>
                                    </td>
                                    <td style="border:1px solid #888; text-align:right;">
                                        <t t-esc="'%0.2f' % (cobros_totals.get('instru_pag') or 0.0)"/>
                                    </td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                    </t>

                    <!-- Nueva página: Resumen de Ingresos -->
                    <t t-if="'ingresos' in selected_section_codes">
                    <div class="page" style="font-size:11px; page-break-before:always;">
                        <div style="text-align:center; font-weight:bold; font-size:20px; margin-bottom:10px; letter-spacing:1px;">
                            <t t-esc="company.name or ''"/>
                        </div>
                        <div style="text-align:center; font-size:16px; font-weight:bold; margin-bottom:6px; text-decoration:underline;">
                            RESUMEN DE INGRESOS
                        </div>
                        <div style="text-align:center; font-size:12px; margin-bottom:18px;">
                            <strong>Periodo:</strong>
                            <t t-esc="doc.start_date or ''"/> a <t t-esc="doc.end_date or ''"/>
                        </div>
                        <table style="width:80%; margin:0 auto 24px auto; font-size:13px; border-collapse:separate; border-spacing:0 6px;">
                            <tr style="background:#f2f2f2; font-weight:bold;">
                                <td colspan="2" style="padding:6px 0 4px 8px; font-size:15px; border-radius:6px 6px 0 0;">RESUMEN DE VENTAS</td>
                            </tr>
                            <tr><td style="width:60%;">Total VENTAS</td><td style="text-align:right; width:40%;"><t t-esc="'%0.2f' % (general_summary.get('total_ventas') or 0.0)"/></td></tr>
                            <tr><td>Total I.V.A.</td><td style="text-align:right;"><t t-esc="'%0.2f' % (general_summary.get('total_iva') or 0.0)"/></td></tr>
                            <tr><td colspan="2" style="height:8px;"></td></tr>
                            <tr style="font-weight:bold; background:#e6f7ff;">
                                <td>Total OPERACION</td>
                                <td style="text-align:right;"><t t-esc="'%0.2f' % (general_summary.get('total_oper') or 0.0)"/></td>
                            </tr>
                            <tr><td>Total ventas a CONTADO</td><td style="text-align:right;"><t t-esc="'%0.2f' % (general_summary.get('total_contado') or 0.0)"/></td></tr>
                            <tr><td>Total ventas a CREDITO</td><td style="text-align:right;"><t t-esc="'%0.2f' % (general_summary.get('total_credito') or 0.0)"/></td></tr>
                            <tr><td colspan="2" style="height:8px;"></td></tr>
                            <!-- Mostrar solo productos ALMACENABLES (storable) -->
                            <tr><td>Total ventas Productos</td><td style="text-align:right;"><t t-esc="'%0.2f' % (general_summary.get('total_ventas_productos') or 0.0)"/></td></tr>
                            <tr><td>Total ventas Servicios</td><td style="text-align:right;"><t t-esc="'%0.2f' % (general_summary.get('total_ventas_servicios') or 0.0)"/></td></tr>
                        </table>
                        <table style="width:80%; margin:0 auto; font-size:13px; border-collapse:separate; border-spacing:0 6px;">
                            <tr style="background:#f2f2f2; font-weight:bold;">
                                <td colspan="2" style="padding:6px 0 4px 8px; font-size:15px; border-radius:6px 6px 0 0;">RESUMEN DE CAJA</td>
                            </tr>
                            <tr><td colspan="2" style="height:4px;"></td></tr>
                            <tr><td style="font-weight:bold;">Ingresos por ventas</td><td></td></tr>
                            <tr><td>EFECTIVO</td><td style="text-align:right;"><t t-esc="'%0.2f' % (general_summary.get('ingresos_efectivo') or 0.0)"/></td></tr>
                            <tr><td>TRANSFERENCIA</td><td style="text-align:right;"><t t-esc="'%0.2f' % (general_summary.get('ingresos_transferencia') or 0.0)"/></td></tr>
                            <tr><td>INSTRUMENTOS DE PAGO</td><td style="text-align:right;"><t t-esc="'%0.2f' % (general_summary.get('ingresos_instrumento') or 0.0)"/></td></tr>
                            <tr><td>ADELANTOS APLICADOS</td><td style="text-align:right;"><t t-esc="'%0.2f' % (general_summary.get('ingresos_adelantos_aplicados') or 0.0)"/></td></tr>
                            <tr><td colspan="2" style="height:8px;"></td></tr>
                            <!-- Se eliminan secciones 'Cobros totales' y 'Pagos adelantados' según requerimiento -->
                            <tr><td colspan="2" style="height:8px;"></td></tr>
                            <tr><td>Total de Ingresos en EFECTIVO</td><td style="text-align:right;"><t t-esc="'%0.2f' % (general_summary.get('total_ingresos_efectivo') or 0.0)"/></td></tr>
                            <tr><td>Total de Ingresos en TRANSFERENCIA</td><td style="text-align:right;"><t t-esc="'%0.2f' % (general_summary.get('total_ingresos_transferencia') or 0.0)"/></td></tr>
                            
                            <tr><td>Total de ingresos en INSTRUMENTOS DE PAGO</td><td style="text-align:right;"><t t-esc="'%0.2f' % (general_summary.get('total_ingresos_instrumento') or 0.0)"/></td></tr>
                            <tr><td colspan="2" style="height:8px;"></td></tr>
                            <tr style="font-weight:bold; background:#e6f7ff;">
                                <td>TOTAL INGRESOS</td>
                                <td style="text-align:right;"><t t-esc="'%0.2f' % (general_summary.get('total_ingresos') or 0.0)"/></td>
                            </tr>
                            <tr><td colspan="2" style="height:8px;"></td></tr>
                            <tr><td>Número de Facturas</td><td style="text-align:right;"><t t-esc="general_summary.get('num_facturas') or 0"/></td></tr>
                            <tr><td>Número de devoluciones</td><td style="text-align:right;"><t t-esc="general_summary.get('num_devoluciones') or 0"/></td></tr>
                            <tr><td>ADELANTOS APLICADOS</td><td style="text-align:right;"><t t-esc="'%0.2f' % (general_summary.get('adelantos_aplicados') or 0.0)"/></td></tr>
                            <tr><td>NOTAS DE CRÉDITO APLICADAS</td><td style="text-align:right;"><t t-esc="'%0.2f' % (general_summary.get('notas_credito_aplicadas') or 0.0)"/></td></tr>
                            <tr><td>TOTAL VENTAS EXENTAS</td><td style="text-align:right;"><t t-esc="'%0.2f' % (general_summary.get('total_ventas_exentas') or 0.0)"/></td></tr>
                            <tr><td>TOTAL DEVOLUCIONES</td><td style="text-align:right;"><t t-esc="'%0.2f' % (general_summary.get('total_devoluciones') or 0.0)"/></td></tr>
                        </table>
                    </div>
                    </t>
                </t>
            </t>
        </t>
    </template>

    <report
        id="report_cash_closure_pdf"
        model="cash.closure.report.wizard"
        string="Cierre de Caja"
        report_type="qweb-pdf"
        name="account_cash_closure_report.report_cash_closure_pdf_template"
        file="account_cash_closure_report.report_cash_closure_pdf_template"
        print_report_name="'cierre_caja_%s_a_%s' % (object.start_date or '', object.end_date or '')"
    />
</odoo>