<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_cash_closure_wizard_form" model="ir.ui.view">
        <field name="name">cash.closure.report.wizard.form</field>
        <field name="model">cash.closure.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Cierre de Caja">
                <group>
                    <group>
                        <field name="start_date" required="1"/>
                        <field name="end_date" required="1"/>
                    </group>
                    <group>
                        <field name="partner_id"/>
                        <field name="user_id"/>
                        <field name="team_id"/>
                    </group>
                </group>
                <group>
                    <field name="report_section_ids" widget="many2many_tags" options="{'no_create': True}"/>
                </group>
                <footer>
                    <button string="Imprimir PDF" type="object" name="action_print_pdf" class="btn-primary"/>
                    <button string="Exportar XLSX" type="object" name="action_export_xlsx"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_cash_closure_wizard" model="ir.actions.act_window">
        <field name="name">Cierre de Caja</field>
        <field name="res_model">cash.closure.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Menu: Contabilidad / Reportes / Cierre de Caja -->
    <menuitem id="menu_cash_closure_root" name="Cierre de Caja"
              parent="account.menu_finance_reports"
              action="action_cash_closure_wizard"
              sequence="90"/>
</odoo>
