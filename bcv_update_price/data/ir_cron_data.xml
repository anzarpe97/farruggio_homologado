<!-- data/ir_cron_data.xml -->
<odoo>
    <data noupdate="1">
        <!-- Acción 1: Actualizar productos USD todos los días a las 7:00 AM -->
        <record id="ir_cron_actualizar_productos_usd" model="ir.cron">
            <field name="name">Actualizar productos USD</field>
            <field name="model_id" ref="base.model_res_currency"/>
            <field name="state">code</field>
            <field name="code">model.search([('name', '=', 'USD')]).actualizar_productos()</field>
            <field name="user_id" ref="base.user_admin"/>
            <field name="active" eval="True"/>
            <field name="interval_number" eval="1"/>
            <field name="interval_type">days</field>
            <field name="numbercall" eval="-1"/>
            <field name="nextcall">2025-02-09 07:00:00</field>
        </record>
    </data>
</odoo>
