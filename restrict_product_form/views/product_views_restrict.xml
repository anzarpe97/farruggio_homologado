<odoo>
    <!-- Vista tree personalizada para el grupo restringido -->
    <record id="product_template_tree_restrict" model="ir.ui.view">
        <field name="name">product.template.tree.restrict</field>
        <field name="model">product.template</field>
        <field name="groups_id" eval="[(4, ref('restrict_product_form.group_restrict_product_form'))]"/>
        <field name="priority" eval="100"/>
        <field name="arch" type="xml">
            <tree string="Productos">
                <field name="categ_id"/>
                <field name="name" width="240px"/>
                <field name="default_code"/>
                <field name="list_price_usd"/>
                <!-- <field name="qty_available"/> -->
                <field name="uom_id"/>
            </tree>
        </field>
    </record>

    <!-- Acción personalizada: solo vista tree de product.template -->
    <record id="product_normal_action_restrict" model="ir.actions.act_window">
        <field name="name">Productos</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="restrict_product_form.product_template_tree_restrict"/>
    </record>
    <!-- Menú raíz solo para el grupo restringido -->
    <menuitem id="restrict_product_form_menu_root" name="Catálogo de Producto" web_icon="restrict_product_form,static/description/icon.png" groups="restrict_product_form.group_restrict_product_form"/>

    <!-- Menú secundario bajo el menú raíz -->
    <record id="restrict_product_form_menu" model="ir.ui.menu">
        <field name="name">Productos</field>
        <field name="action" ref="product_normal_action_restrict"/>
        <field name="parent_id" ref="restrict_product_form_menu_root"/>
        <field name="groups_id" eval="[(4, ref('restrict_product_form.group_restrict_product_form'))]"/>
    </record>
</odoo>
