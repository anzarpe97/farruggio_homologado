<odoo>
  <record id="view_intercompany_transfer_form" model="ir.ui.view">
    <field name="name">intercompany.transfer.form</field>
    <field name="model">intercompany.transfer</field>
    <field name="arch" type="xml">
      <form string="Transferencia entre compañías">
        <header>
            <button name="action_transfer"
                    type="object"
                    string="Validar"
                    class="btn-primary"
                    attrs="{'invisible': [('state', '=', 'done')]}" />
            <field name="state" widget="statusbar" statusbar_visible="draft,done"/>
        </header>
        <sheet>
                <group>
                    <field name="reference" attrs="{'readonly': [('state', '=', 'done')]}"/>
                    <field name="transfer_date" attrs="{'readonly': [('state', '=', 'done')]}"/>
                    <field name="company_id" required="1" attrs="{'readonly': [('state', '=', 'done')]}"/>
                    <field name="company_to_id" required="1" attrs="{'readonly': [('state', '=', 'done')]}"/>
                    <field name="location_id" required="1" attrs="{'readonly': [('state', '=', 'done')]}"/>
                    <field name="location_dest_id" required="1" attrs="{'readonly': [('state', '=', 'done')]}"/>
                </group>

                <notebook>
                    <page string="Líneas de Producto">
                        <field name="product_line_ids" attrs="{'readonly': [('state', '=', 'done')]}">
                            <tree editable="bottom">
                                <field name="product_id"/>
                                <field name="quantity"/>
                            </tree>
                        </field>
                    </page>

                    <page string="Documentos Relacionados">
                        <group>
                            <field name="picking_id_out" readonly="1" widget="many2one"/>
                            <field name="picking_id_in" readonly="1" widget="many2one"/>
                            <field name="picking_id_return" readonly="1"/>
                        </group>
                    </page>
                </notebook>
            </sheet>
        <footer>
          <button name="action_transfer" string="Transferir" type="object" class="btn-primary"/>
        </footer>
      </form>
    </field>
  </record>

  <record id="action_intercompany_transfer" model="ir.actions.act_window">
    <field name="name">Transferencias Intercompañía</field>
    <field name="res_model">intercompany.transfer</field>
    <field name="view_mode">tree,form</field>
  </record>

    <menuitem id="menu_intercompany_transfer_root"
            name="Transferencias Intercompañía"
            sequence="10"
            web_icon="intercompany_transfer,static/description/icon.png" />

    <menuitem id="menu_intercompany_transfer_main"
            name="Transferencias"
            parent="menu_intercompany_transfer_root"
            action="action_intercompany_transfer" />
</odoo>