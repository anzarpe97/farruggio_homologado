<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista Tree Mejorada -->
    <record id="view_cobranza_factura_tree" model="ir.ui.view">
        <field name="name">cobranza.factura.tree</field>
        <field name="model">cobranza.factura</field>
        <field name="arch" type="xml">
            <tree string="Facturas de Cobranza" 
                create="0" 
                edit="1" 
                delete="1"
                class="modern-dashboard-tree"
                multi_edit="1"
                decoration-danger="estado in ('moroso','critico')"
                decoration-warning="estado == 'vencido'"
                decoration-success="estado == 'a_vencer'">
                <field name="zona" string="Zona" optional="show"/>
                <field name="factura" string="Factura"/>
                <field name="cliente" string="Cliente"/>
                <field name="fecha_factura" string="Fecha Factura" widget="date"/>
                <field name="fecha_vencimiento" string="Fecha Vencimiento" widget="date"/>
                <field name="monto_factura" string="Monto Factura"/>
                <field name="deuda_usd" string="Deuda USD" widget="monetary" sum="Total"/>
                <field name="dias" string="Días vencido" widget="integer"/>
                <field name="estado" string="Estado" widget="badge"/>
                <field name="plazo_dias" invisible="1"/>
            </tree>
        </field>
    </record>

    <!-- Vista Form Mejorada -->
    <record id="view_cobranza_factura_form" model="ir.ui.view">
        <field name="name">cobranza.factura.form</field>
        <field name="model">cobranza.factura</field>
        <field name="arch" type="xml">
            <form string="Factura de Cobranza" class="modern-dashboard-form">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <span class="oe_inline">N° Factura - (</span>
                            <field name="factura" class="oe_inline" readonly="1"/>
                            <span class="oe_inline">)</span>
                        </h1>
                    </div>
                    <group>
                        <group string="Información del Cliente">
                            <field name="cliente" class="field-modern" options="{'no_create': True}" readonly="1"/>
                            <field name="zona" class="field-modern" readonly="1"/>
                        </group>
                        <group string="Información Financiera">
                            <field name="fecha_factura" class="field-modern" widget="date" readonly="1"/>
                            <field name="monto_factura" class="field-modern" readonly="1"/>
                            <field name="tax_today" class="field-modern" readonly="1"/>
                            <field name="deuda_usd" class="field-modern" widget="monetary" readonly="1"/>
                            <field name="dias" class="field-modern" readonly="1"/>
                            <field name="estado" class="field-modern" widget="badge" readonly="1"/>
                            <field name="plazo_dias" class="field-modern" readonly="1"/>
                            <field name="fecha_vencimiento" class="field-modern" widget="date" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Detalles Adicionales">
                            <group>
                                <group string="Información de Seguimiento">
                                    <field name="create_date" string="Fecha de Creación" readonly="1"/>
                                    <field name="write_date" string="Última Actualización" readonly="1"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vista Kanban Mejorada -->
    <record id="view_cobranza_factura_kanban" model="ir.ui.view">
        <field name="name">cobranza.factura.kanban</field>
        <field name="model">cobranza.factura</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile modern-dashboard-kanban" create="0">
                <field name="cliente"/>
                <field name="factura"/>
                <field name="monto_factura"/>
                <field name="tax_today"/>
                <field name="deuda_usd"/>
                <field name="dias"/>
                <field name="estado"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_card oe_kanban_global_click 
                                          #{record.estado.raw_value == 'moroso' ? 'status-overdue-critical' : ''}
                                          #{record.estado.raw_value == 'critico' ? 'status-overdue-critical' : ''}
                                          #{record.estado.raw_value == 'vencido' ? 'status-overdue-warning' : ''}
                                          #{record.estado.raw_value == 'a_vencer' ? 'status-current' : ''}">
                            <div class="o_kanban_card_header">
                                <div class="o_kanban_card_header_title">
                                    <div class="o_primary">
                                        <strong><field name="factura"/></strong>
                                    </div>
                                    <div class="o_secondary">
                                        <field name="cliente"/>
                                    </div>
                                </div>
                            </div>
                            <div class="o_kanban_card_body">
                                <div>
                                    <i class="fa fa-calculator"/> <field name="monto_factura"/>
                                    <div><i class="fa fa-exchange"/> Tasa: <field name="tax_today"/></div>
                                    <i class="fa fa-usd"/> <field name="deuda_usd" widget="monetary"/>
                                </div>
                                <div>
                                    <i class="fa fa-calendar"/> <field name="dias"/> días
                                </div>
                            </div>
                            <div class="o_kanban_card_footer">
                                <div>
                                    <field name="estado" widget="badge"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Vista de Búsqueda Mejorada -->
    <record id="view_cobranza_factura_search" model="ir.ui.view">
        <field name="name">cobranza.factura.search</field>
        <field name="model">cobranza.factura</field>
        <field name="arch" type="xml">
            <search string="Buscar Facturas">
                <field name="cliente" string="Cliente" filter_domain="[('cliente', 'ilike', self)]"/>
                <field name="zona" string="Zona"/>
                <field name="factura" string="Factura"/>
                <filter string="Crítico (>30 días)" name="filter_critical" domain="[('dias', '&gt;=', 31)]"/>
                <filter string="Advertencia (20-30 días)" name="filter_warning" domain="[('dias', '&gt;=', 20), ('dias', '&lt;', 31)]"/>
                <filter string="Pendiente (1-19 días)" name="filter_medium" domain="[('dias', '&gt;=', 1), ('dias', '&lt;', 20)]"/>
                <filter string="A Vencer" name="filter_a_vencer" domain="[('estado', '=', 'a_vencer')]"/>
                <separator/>
                
                <group expand="0" string="Agrupar Por">
                    <filter string="Cliente" name="group_by_cliente" context="{'group_by': 'cliente'}"/>
                    <filter string="Zona" name="group_by_zona" context="{'group_by': 'zona'}"/>
                    <filter string="Estado" name="group_by_estado" context="{'group_by': 'estado'}"/>
                    <filter string="Mes de Factura" name="group_by_month" context="{'group_by': 'fecha_factura:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Vista Pivot para Análisis -->
    <record id="view_cobranza_factura_pivot" model="ir.ui.view">
        <field name="name">cobranza.factura.pivot</field>
        <field name="model">cobranza.factura</field>
        <field name="arch" type="xml">
            <pivot string="Análisis de Cobranza">
                <field name="zona" type="row"/>
                <field name="estado" type="col"/>
                <field name="monto_factura" type="measure"/>
                <field name="deuda_usd" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Vista Graph para Reportes -->
    <record id="view_cobranza_factura_graph" model="ir.ui.view">
        <field name="name">cobranza.factura.graph</field>
        <field name="model">cobranza.factura</field>
        <field name="arch" type="xml">
            <graph string="Gráfico de Cobranza" type="bar">
                <field name="zona"/>
                <field name="deuda_usd" type="measure"/>
            </graph>
        </field>
    </record>


    <record id="action_cobranza_dashboard" model="ir.actions.act_window">
        <field name="name">Dashboard de Cobranza</field>
        <field name="res_model">cobranza.factura</field>
        <field name="view_mode">tree,kanban,form,pivot,graph</field>
        <field name="view_id" ref="view_cobranza_factura_tree"/>
        <field name="target">current</field>
        <field name="context">{
            'search_default_filter_warning': 1,
            'search_default_filter_critical': 1,
        }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No tienes facturas de cobranza aún
            </p>
            <p>
                Gestiona todas tus facturas y mantén un seguimiento efectivo de los pagos.
            </p>
        </field>
    </record>

    <!-- Menú Principal -->
    <menuitem id="menu_cobranza_root" 
              name="Cobranzas" 
              sequence="10"
              web_icon="collection_dashboard,static/description/icon-menu.png"/>
    
    <menuitem id="menu_cobranza_dashboard" 
              name="Cobranza Por Zona" 
              parent="menu_cobranza_root" 
              action="action_cobranza_dashboard" 
              sequence="1"/>
</odoo>