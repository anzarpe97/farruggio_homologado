<odoo>

    <record id="inventory_adjustments_search_view" model="ir.ui.view">
        <field name="name">inventory.adjustments.search_view</field>
        <field name="model">stock.inventory</field>
        <field eval="10" name="priority"/>
        <field name="arch" type="xml">
            <search string="Inventario de Stock">
                <field name="name" />
                <field name="location_id" />
                <filter name="my_inventory" string="Mi Inventario" domain="[('user_id', '=', uid)]"/>
                <filter name="inventory_date" string="Fecha de Inventario" date="date"/>
                <group expand="0" string="Agrupar por">
                    <filter string="Fecha de Inventario" name="date"  context="{'group_by': 'date'}"/>
                    <filter string="Ubicación" name="location_id"  context="{'group_by': 'location_id'}"/>
                    <filter string="Estado" name="state"  context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="inventory_adjustments_list_view" model="ir.ui.view">
        <field name="name">inventory.adjustments.views.list</field>
        <field name="model">stock.inventory</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="date"/>
                <field name="write_uid"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="inventory_adjustments_form_view" model="ir.ui.view">
        <field name="name">Inventory Adjustments</field>
        <field name="model">stock.inventory</field>
        <field eval="1" name="priority"/>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="prepare_inventory_stock_counting" states="draft" string="Iniciar Inventario" type="object" class="oe_highlight" groups="inventory_stock_adjustments.group_stock_adjustments_user"/>
                    <button name="action_send_for_approval" states="confirm" string="Enviar para Aprobación" type="object" class="oe_highlight" groups="inventory_stock_adjustments.group_stock_adjustments_user"/>
                    <button name="action_approved" states="wait_for_approval" string="Aprobar" type="object" class="oe_highlight" groups="inventory_stock_adjustments.group_stock_adjustments_manager"/>
                    <button name="action_done" states="approved" string="Validar Inventario" type="object" class="oe_highlight"/>
                    <button name="action_cancel_draft" states="cancel" string="Volver a Borrador" type="object"/>
                    <button name="action_cancel_draft" states="confirm" string="Cancelar Inventario" type="object"/>
                    <button name="action_cancel_draft" states="wait_for_approval" string="Cancelar Inventario" type="object"/>
                    <button name="action_cancel_draft" states="approved" string="Cancelar Inventario" type="object"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirm,wait_for_approval,done"/>
                </header>
                <sheet>
                <div class="oe_title">
                    <label for="name" class="oe_edit_only"/>
                    <h1><field name="name" placeholder="Ej: Inventario anual"/></h1>
                </div>
                <group>
                    <group>
                        <field name="location_id" string="Ubicación Inventariada" attrs="{'readonly':[('state', '!=', 'draft')]}"/>
                        <field name="filter" string="Inventario de" widget='radio' attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                        <field name="date" string="Fecha de Inventario"/>
                        <field name="accounting_date" string="Forzar Fecha Contable" attrs="{'readonly':[('state', '!=', 'draft')]}"/>
                        <field name="company_id" options="{'no_create': True}" />
                        <field name="product_id" domain="[('type','=','product')]" attrs="{'invisible': [('filter', 'not in', ('product', 'product_owner'))], 'required': [('filter', 'in', ('product', 'product_owner'))]}"/>
                        <field name="category_id" attrs="{'invisible': [('filter', 'not in','category')], 'required': [('filter', 'in', 'category')]}" options="{'no_create': True}"/>
                        <field name="lot_id" attrs="{'invisible': [('filter', '!=', 'lot')], 'required': [('filter', '=', 'lot')]}" />
                        <field name="partner_id" attrs="{'invisible': [('filter', 'not in', ('owner', 'product_owner'))], 'required': [('filter', 'in', ('owner', 'product_owner'))]}" />
                        <field name="package_id" attrs="{'invisible': [('filter', '!=', 'pack')], 'required': [('filter', '=', 'pack')]}" />
                        <field name="add_onhand_zero"/>
                        <button name="set_product_serial_type_quantity" type="object" string="FIJAR CANTIDAD PARA N° DE SERIE" attrs="{'invisible':[('state','in',['done', 'cancel'])]}" class="btn btn-primary"/>
                    </group>
                </group>
                <notebook attrs="{'invisible':[('state','=','draft')]}">
                    <page string="Detalles de Inventario" >
                        <!-- <button name="reset_real_qty" states="confirm" string="⇒ Set quantities to 0" type="object" class="oe_link oe_right" groups="stock.group_stock_user"/> -->
                        <field name="line_ids" widget="stock_move_one2many" string="Detalles de Inventario" context="{'default_location_id': location_id,  'default_product_id': product_id, 'default_prod_lot_id': lot_id, 'default_package_id': package_id, 'default_partner_id': partner_id}" mode="tree">
                            <tree string="Detalles de Inventario" editable="top" edit="1" create="1" delete="1">
                                <field name="product_id"  domain="[('detailed_type','=','product')]"/>
                                <field name="product_uom_id" string="Unidad de Medida" groups="uom.group_uom"/>
                                <field name="location_id" domain="[('id', 'child_of', parent.location_id)]" groups="stock.group_stock_multi_locations" invisible="1"/>
                                <field name="prod_lot_id" domain="[('product_id', '=', product_id)]" context="{'default_product_id': product_id}"  groups="stock.group_production_lot" attrs="{'required': [('lot_serial', '=', True)]}"/>
                                <field name="package_id" groups="stock.group_tracking_lot"/>
                                <field name="lot_id" />
                                <field name="lot_serial"/>
                                <button name="select_stock_inventory_line" type="object" icon="fa-list" title="Abrir ventana de números de serie" width="0.1" attrs="{'invisible':[('lot_id','=',False),('lot_serial','=',False)]}"/>
                                <field name="currency_id" invisible="1"/>
                                <field name="price_value" decoration-danger="inventory_quantity &lt; quantity" decoration-success="inventory_quantity &gt; quantity" widget="monetary" options="{'currency_field': 'currency_id'}" sum="Valor Total"/>
                                <field name="partner_id" groups="stock.group_tracking_owner"/>
                                <field name="available_quantity" decoration-info="available_quantity != quantity" force_save="1" string="Cantidad Disponible"/>
                                <field name="reserved_quantity" string="Cantidad Reservada"/>
                                <button name="do_unreserve_product_qty" type="object" string="Anular Reserva" width="1" attrs="{'invisible':[('reserved_quantity','=',0)]}"/>
                                <field name="quantity" decoration-info="available_quantity != quantity" force_save="1" string="Cantidad"/>
                                <field name="make_it_zero" decoration-danger="make_it_zero" force_save="1" string="Poner en Cero"/>
                                <field name="inventory_quantity" decoration-danger="inventory_quantity &lt; quantity" decoration-success="inventory_quantity &gt; quantity" string="Cantidad Contada"/>
                                <field name="state" invisible="True"/>
                            </tree>
                        </field>
                        <p></p>
                        <h3>Nota Importante</h3>
                        <group name="note_group" col="6" class="mt-2 mt-md-0">
                            <group colspan="4">
                                <field colspan="2" name="note" nolabel="1" placeholder="Agrega notas aquí..."/>
                            </group>
                        </group>
                        <h3 class="oe_grey">Notas</h3>
                        <ul>
                            <li>Los ajustes de inventario se basan en la comparación de la **Cantidad Disponible**, **Cantidad en Mano** y la **Cantidad Contada**.</li>
                            <li>Tienes la opción de **eliminar líneas** para omitir productos específicos del ajuste.</li>
                            <li>Si un producto está en la ubicación incorrecta, simplemente **crea una nueva línea** para registrar su ubicación correcta.</li>
                        </ul>
                    </page>
                </notebook>
            </sheet>
            </form>
        </field>
    </record>


    <record id="action_view_inventory_adjustments_form" model="ir.actions.act_window">
        <field name="name">Ajuste de Inventario</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">stock.inventory</field>
        <field name="view_mode">tree,form,search</field>
        <field name="view_id" ref="inventory_stock_adjustments.inventory_adjustments_list_view"/>
        <field name="context"></field>
    </record>

    <menuitem id="menu_action_inventory_form" name="Ajustes de Inventario Por Aprobaciones" parent="stock.menu_stock_warehouse_mgmt" sequence="11" action="action_view_inventory_adjustments_form" groups="inventory_stock_adjustments.group_stock_adjustments_user" />
</odoo>