<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Solo heredamos el wizard nativo para añadir campos -->
    <record id="view_stock_quantity_history_inherit_locations" model="ir.ui.view">
        <field name="name">stock.quantity.history.form.inherit.locations</field>
        <field name="model">stock.quantity.history</field>
        <field name="inherit_id" ref="stock.view_stock_quantity_history"/>
        <field name="arch" type="xml">
            <xpath expr="//group" position="inside">
                <!-- <field name="location_ids" widget="many2many_tags"/>
                <field name="group_by_warehouse"/> -->
            </xpath>
        </field>
    </record>
    <!-- Vista árbol para líneas por ubicación -->
    <record id="view_stock_quantity_history_location_line_tree" model="ir.ui.view">
        <field name="name">stock.quantity.history.location.line.tree</field>
        <field name="model">stock.quantity.history.location.line</field>
        <field name="arch" type="xml">
            <tree string="Inventario a la Fecha (Ubicaciones)" create="0" edit="0" delete="0">
                <field name="product_id"/>
                <field name="default_code" optional="hide"/>
                <field name="categ_id" optional="hide"/>
                <field name="location_id"/>
                <field name="warehouse_id" optional="hide"/>
                <field name="quantity"/>
                <field name="uom_id" optional="hide"/>
                <field name="cost_unit" optional="hide"/>
                <field name="value_total" optional="show"/>
            </tree>
        </field>
    </record>

    <record id="view_stock_quantity_history_location_line_pivot" model="ir.ui.view">
        <field name="name">stock.quantity.history.location.line.pivot</field>
        <field name="model">stock.quantity.history.location.line</field>
        <field name="arch" type="xml">
            <pivot string="Inventario a la Fecha (Pivot)">
                <field name="product_id" type="row"/>
                <field name="location_id" type="col"/>
                <field name="warehouse_id" type="col" optional="show"/>
                <field name="quantity" type="measure"/>
                <field name="value_total" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_stock_quantity_history_location_line_search" model="ir.ui.view">
        <field name="name">stock.quantity.history.location.line.search</field>
        <field name="model">stock.quantity.history.location.line</field>
        <field name="arch" type="xml">
            <search string="Buscar Detalle Inventario a la Fecha">
                <field name="product_id"/>
                <field name="location_id"/>
                <field name="warehouse_id"/>
                <field name="categ_id"/>
                <filter name="positive" string="Cantidad &gt; 0" domain="[('quantity','>',0)]"/>
                <!-- En el dominio se debe escapar '<' como &lt; para XML -->
                <filter name="negative" string="Cantidad &lt; 0" domain="[('quantity','&lt;',0)]"/>
                <filter name="zero" string="Cantidad = 0" domain="[('quantity','=',0)]"/>
                <group expand="0" string="Agrupar por">
                    <filter name="grp_product" string="Producto" context="{'group_by':'product_id'}"/>
                    <filter name="grp_location" string="Ubicación" context="{'group_by':'location_id'}"/>
                    <filter name="grp_warehouse" string="Almacén" context="{'group_by':'warehouse_id'}"/>
                    <filter name="grp_category" string="Categoría" context="{'group_by':'categ_id'}"/>
                </group>
            </search>
        </field>
    </record>
</odoo>
