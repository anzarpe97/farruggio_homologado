<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit the main stock.quant tree to ensure location is always visible -->
    <record id="view_stock_quant_tree_inherit_location_column" model="ir.ui.view">
        <field name="name">stock.quant.tree.inherit.location.column</field>
        <field name="model">stock.quant</field>
        <field name="inherit_id" ref="stock.view_stock_quant_tree"/>
        <field name="arch" type="xml">
            <!-- Insert location_id after product_id if not already there -->
            <xpath expr="//tree/field[@name='product_id']" position="after">
                <field name="location_id"/>
            </xpath>
        </field>
    </record>
</odoo>
