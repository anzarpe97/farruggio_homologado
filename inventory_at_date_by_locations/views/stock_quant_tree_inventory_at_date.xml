<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Small tree view for stock.quant used when showing results from Inventario a la Fecha -->
    <record id="view_stock_quant_tree_inventory_at_date" model="ir.ui.view">
        <field name="name">stock.quant.tree.inventory.at.date</field>
        <field name="model">stock.quant</field>
        <field name="arch" type="xml">
            <tree string="Quants (Inventario a la Fecha)">
                <field name="product_id"/>
                <field name="location_id"/>
                <field name="quantity"/>
                <field name="package_id"/>
                <field name="lot_id"/>
            </tree>
        </field>
    </record>
</odoo>
