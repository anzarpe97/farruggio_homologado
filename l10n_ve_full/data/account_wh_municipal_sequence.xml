<odoo>
    <!-- Secuencia para el campo "name" de account.wh.municipal -->
    <record id="seq_account_wh_municipal_doc" model="ir.sequence">
        <field name="name">Secuencia Retención Municipal</field>
        <field name="code">account.wh.municipal.doc</field>
        <field name="prefix">RM/</field>
        <field name="padding">6</field>
        <field name="company_id" eval="False"/>
    </record>

    <!-- Secuencia para el campo "municipal_number_asignado" -->
    <record id="seq_account_wh_municipal_number" model="ir.sequence">
        <field name="name">Número de Retención Municipal</field>
        <field name="code">account.wh.municipal.number</field>
        <field name="padding">10</field>
        <field name="company_id" eval="False"/>
    </record>
</odoo>
