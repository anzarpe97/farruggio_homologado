<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="template_wh_vat">
            <t t-call="web.html_container">
            <t t-foreach="data" t-as="d">
                <div class="article">
                    <style>
                        .vat-header-table, .vat-info-table, .vat-summary-table, .vat-main-table {
                            width: 100%;
                            border-collapse: collapse;
                            font-size: 11px;
                        }
                        .vat-header-table td,
                        .vat-info-table td,
                        .vat-info-table th,
                        .vat-summary-table th,
                        .vat-summary-table td,
                        .vat-main-table th,
                        .vat-main-table td {
                            border: 1px solid #c2c2c2;
                            padding: 7px 6px;
                            text-align: center;
                            vertical-align: middle;
                            font-family: 'Arial', sans-serif;
                        }
                        .vat-header-table {
                            margin-bottom: 0.2em;
                        }
                        .vat-header-title {
                            font-size: 20px;
                            font-weight: bold;
                            color: #383838;
                            letter-spacing: 1px;
                            text-align: left;
                        }
                        .vat-header-law {
                            font-size: 10px;
                            color: #777;
                            text-align: left;
                        }
                        .vat-info-table th {
                            background: #f4f4f4;
                            font-weight: bold;
                            font-size: 11px;
                            border-bottom: 2px solid #888;
                        }
                        .vat-info-table td {
                            text-align: left;
                            background: #fff;
                        }
                        .vat-summary-table th {
                            background: #e6e8eb;
                            font-weight: bold;
                        }
                        .vat-summary-table td {
                            background: #fcfcfc;
                        }
                        .vat-main-table th {
                            background: #ddeaf7;
                            color: #252525;
                            font-size: 11px;
                            font-weight: bold;
                            border-bottom: 2px solid #707070;
                        }
                        .vat-main-table td {
                            background: #fff;
                            font-size: 10.5px;
                        }
                        .vat-main-table tfoot td {
                            font-weight: bold;
                            background: #e9f0f6;
                            border-top: 2px solid #585858;
                            font-size: 11px;
                        }
                        .vat-sign-section td {
                            border: none !important;
                            text-align: center;
                            padding-top: 28px;
                            font-size: 12px;
                        }
                        .vat-sign-section img {
                            margin-bottom: 6px;
                        }
                        hr {
                            border: 1px solid #b0b0b0;
                            width: 55%;
                            margin-left: auto;
                            margin-right: auto;
                            margin-top: 10px;
                            margin-bottom: 0px;
                        }
                    </style>
                    <table class="vat-header-table">
                        <tr>
                            <td style="width:20%;">
                                <img t-att-src="image_data_uri(d.company_id.logo)" style="width:180px; height:85px;"/>
                            </td>
                            <td style="width:35%;">
                                <div class="vat-header-title">
                                    Comprobante de Retención de IVA
                                </div>
                            </td>
                            <td style="width:45%;">
                                <div class="vat-header-law">
                                    LEY IVA – ART. 11: “SERÁN RESPONSABLES DEL PAGO DE IMPUESTO EN CALIDAD DE AGENTES DE RETENCIÓN, LOS COMPRADORES O ADQUIRIENTES DE DETERMINADOS BIENES MUEBLES Y LOS RECEPTORES DE CIERTOS SERVICIOS A QUIENES LA ADMINISTRACIÓN TRIBUTARIA DESIGNE COMO TAL”
                                </div>
                            </td>
                        </tr>
                    </table>

                    <table class="vat-info-table" style="margin-bottom:4px;">
                        <tr>
                            <th colspan="2">Providencia Administrativa N° SNAT/2015/0049 del 10/08/2015</th>
                            <td colspan="2" style="text-align:right; border:none;">
                                <strong>Nro. Comprobante:</strong>
                                <span t-esc="d.number"/>
                            </td>
                            <td colspan="2" style="text-align:right; border:none;">
                                <strong>Fecha de Contabilización:</strong>
                                <span t-esc="model.get_date(d.date)"/>
                            </td>
                        </tr>
                        <tr>
                            <td colspan="2"><strong>Agente de Retención:</strong></td>
                            <td colspan="2"><strong>RIF Agente de Retención:</strong></td>
                            <td colspan="2"><strong>Período Fiscal:</strong></td>
                        </tr>
                        <tr>
                            <td colspan="2"><span t-esc="d.company_id.partner_id.name"/></td>
                            <td colspan="2"><span t-esc="d.company_id.partner_id.rif"/></td>
                            <td colspan="2"><span t-esc="model.get_period(d.date_ret)"/></td>
                        </tr>
                        <tr>
                            <td colspan="6"><strong>Dirección Fiscal del Agente de Retención:</strong></td>
                        </tr>
                        <tr>
                            <td colspan="6"><span t-esc="model.get_direction(d.company_id.partner_id)"/></td>
                        </tr>
                        <tr>
                            <td colspan="2"><strong>Agente Retenido:</strong></td>
                            <td colspan="4"><strong>RIF Agente Retenido:</strong></td>
                        </tr>
                        <tr>
                            <td colspan="2"><span t-esc="d.partner_id.name"/></td>
                            <td colspan="4"><span t-esc="d.partner_id.rif"/></td>
                        </tr>
                        <tr>
                            <td colspan="6"><strong>Dirección Fiscal del Agente Retenido:</strong></td>
                        </tr>
                        <tr>
                            <td colspan="6"><span t-esc="model.get_direction(d.partner_id)"/></td>
                        </tr>
                    </table>

                    <table class="vat-main-table">
                        <thead>
                            <tr>
                                <th>Fecha de<br/>Operación</th>
                                <th>Nro.<br/>Factura</th>
                                <th>Nro.<br/>Control</th>
                                <th>Nro.<br/>Nota Débito</th>
                                <th>Nro.<br/>Nota Crédito</th>
                                <th>Tipo<br/>Trans.</th>
                                <th>Nro. Factura<br/>Afectada</th>
                                <th>Monto Total<br/>de Documento</th>
                                <th>Compras sin<br/>Derecho a Crédito Fiscal</th>
                                <th>Base<br/>Imponible</th>
                                <th>%<br/>Alicuota</th>
                                <th>Impuesto<br/>Causado</th>
                                <th>Base<br/>Reducido</th>
                                <th>%<br/>Alicuota Reducido</th>
                                <th>Impuesto<br/>Causado Reducido</th>
                                <th>Base<br/>Adicional</th>
                                <th>%<br/>Alicuota Adicional</th>
                                <th>Impuesto<br/>Causado Adicional</th>
                                <th>%<br/>Retención de IVA</th>
                                <th>Monto del<br/>Impuesto Retenido</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td><span t-field="d.wh_lines.invoice_id.invoice_date" t-options='{"format": "dd/MM/yyyy"}'/></td>
                                
                                <td>
                                    <t t-if="not is_nd and not is_nc">
                                        <t t-if="d.wh_lines.type == 'out_invoice'">
                                            <span t-esc="d.wh_lines.invoice_id.name"/>
                                        </t>
                                        <t t-if="d.wh_lines.type in ('in_invoice', 'in_debit', 'in_refund')">
                                            <span t-esc="d.wh_lines.invoice_id.supplier_invoice_number"/>
                                        </t>
                                    </t>
                                </td>
                                
                                <td><span t-esc="inv_nro_ctrl"/></td>
                                
                                <td>
                                    <t t-if="is_nd">
                                        <span t-esc="d.wh_lines.invoice_id.supplier_invoice_number"/>
                                    </t>
                                </td>
                                
                                <td>
                                    <t t-if="is_nc">
                                        <span t-esc="d.wh_lines.invoice_id.supplier_invoice_number"/>
                                    </t>
                                </td>
                                
                                <td>
                                    <t t-if="is_nd">
                                        <span>02-COMP</span>
                                    </t>
                                    <t t-elif="is_nc">
                                        <span>03-COM</span>
                                    </t>
                                    <t t-else="">
                                        <span t-esc="model.get_t_type(d.wh_lines.type)"/>
                                    </t>
                                </td>
                                
                                <td>
                                    <t t-if="affected_invoice">
                                        <span t-esc="affected_invoice"/>
                                    </t>
                                    <t t-elif="is_nc and d.wh_lines.invoice_id.invoice_reverse_purchase_id">
                                        <span t-esc="d.wh_lines.invoice_id.invoice_reverse_purchase_id.supplier_invoice_number"/>
                                    </t>
                                    <t t-elif="is_nd and d.wh_lines.invoice_id.debit_origin_id">
                                        <span t-esc="d.wh_lines.invoice_id.debit_origin_id.supplier_invoice_number"/>
                                    </t>
                                    <t t-elif="inv_nro_fact">
                                        <span t-esc="inv_nro_fact"/>
                                    </t>
                                </td>
                                
                                <td><span t-esc="total_doc"/></td>
                                <td><span t-esc="base_exent"/></td>
                                <td><span t-esc="sum_base_general"/></td>
                                <td><span t-esc="rate_general"/></td>
                                <td><span t-esc="sum_tax_general"/></td>
                                <td><span t-esc="sum_base_reducida"/></td>
                                <td><span t-esc="rate_reducida"/></td>
                                <td><span t-esc="sum_tax_reducida"/></td>
                                <td><span t-esc="sum_base_additional"/></td>
                                <td><span t-esc="rate_additional"/></td>
                                <td><span t-esc="sum_tax_additional"/></td>
                                <td><span t-esc="'{:,.2f}'.format(d.wh_lines.wh_iva_rate).replace(',', '@').replace('.', ',').replace('@', '.')"/></td>
                                <td><span t-esc="'{:,.2f}'.format(d.total_tax_ret).replace(',', '@').replace('.', ',').replace('@', '.')"/></td>
                            </tr>
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="7" style="text-align:right;">Total General:</td>
                                <td><span t-esc="total_doc"/></td>
                                <td><span t-esc="base_exent"/></td>
                                <td><span t-esc="sum_base_general"/></td>
                                <td></td>
                                <td><span t-esc="sum_tax_general"/></td>
                                <td><span t-esc="sum_base_reducida"/></td>
                                <td></td>
                                <td><span t-esc="sum_tax_reducida"/></td>
                                <td><span t-esc="sum_base_additional"/></td>
                                <td></td>
                                <td><span t-esc="sum_tax_additional"/></td>
                                <td><span t-esc="'{:,.2f}'.format(d.wh_lines.wh_iva_rate).replace(',', '@').replace('.', ',').replace('@', '.')"/></td>
                                <td><span t-esc="'{:,.2f}'.format(d.total_tax_ret).replace(',', '@').replace('.', ',').replace('@', '.')"/></td>
                            </tr>
                        </tfoot>
                    </table>

                    <table class="vat-sign-section" style="width:100%;margin-top:20px;">
                        <tr>
                            <td style="width:50%;">
                                <t t-if="confirming_user and confirming_user.firma_digital">
                                    <img t-attf-src="data:image/*;base64,{{confirming_user.firma_digital}}" style="width:180px; height:90px;" />
                                </t>
                                <t t-else="">
                                    <img class="img Firma_falta" src="/l10n_ve_full/static/src/img/Firma_falta.png" style="width:180px; height:90px;"/>
                                </t>
                                <hr/>
                                <b>
                                    <t t-if="confirming_user">
                                        <span t-esc="confirming_user.name"/>
                                    </t>
                                    <t t-else="">
                                        <span t-if="d.company_id.representante_legal" t-esc="d.company_id.representante_legal"/>
                                    </t>
                                </b>
                                <br/>
                                <b>Agente de Retención (Sello y Firma)</b>
                            </td>
                            <td style="width:50%;">
                                <img class="img Firma_falta" src="/l10n_ve_full/static/src/img/Firma_falta.png" style="width:180px; height:90px;"/>
                                <hr/>
                                <b><span t-esc="d.partner_id.name"/></b>
                                <br/>
                                <b>Firma del Beneficiario</b>
                            </td>
                        </tr>
                    </table>
                </div>
            </t>    
            </t>
        </template>

        <record id="paperformat_withholding_vat_report" model="report.paperformat">
            <field name="name">Vat Report</field>
            <field name="orientation">Landscape</field>
            <field name="header_line" eval="False"/>
            <field name="margin_top">25</field>
            <field name="margin_right">5</field>
            <field name="margin_bottom">2</field>
            <field name="margin_left">5</field>
            <field name="header_line" eval="False"/>
            <field name="header_spacing">0</field>
            <field name="dpi">0</field>
        </record>

        <record id="action_withholdong_vat_report" model="ir.actions.report">
            <field name="name">Comprobante de IVA</field>
            <field name="model">account.wh.iva</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">l10n_ve_full.template_wh_vat</field>
            <field name="report_file">l10n_ve_full.template_wh_vat</field>
            <field name="paperformat_id" ref="l10n_ve_full.paperformat_withholding_vat_report"/>
            <field name="binding_model_id" ref="model_account_wh_iva"/>
            <field name="binding_type">report</field>
        </record>
    </data>
</odoo>