<odoo>
    <report
        id="action_report_account_wh_municipal"
        model="account.wh.municipal"
        string="Imprimir Retención Municipal"
        report_type="qweb-pdf"
        name="l10n_ve_full.report_account_wh_municipal"
        file="l10n_ve_full.report_account_wh_municipal"
        print_report_name="'Retención_Municipal_%s' % (object.name)"
    />

    <template id="report_account_wh_municipal">
        <t t-call="web.external_layout">
            <main>
                <t t-foreach="docs" t-as="o">
                    <div class="page">
                        <br/>
                        <div class="text-right">
                            <p style="font-size: 14px;">
                                <b>Número de Comprobante: </b> <span t-field="o.municipal_number_asignado"/><br/>
                                <b>Fecha:</b> <span t-esc="o.date.strftime('%d/%m/%Y')"/><br/>
                                <b>Teléfonos:</b> <span t-esc="o.move_id.company_id.phone or 'N/A'"/><br/>
                            </p>
                        </div>

                        <div class="text-center">
                            <h5><b>RETENCIÓN IMPUESTO MUNICIPAL - SEDEMAT</b></h5>
                        </div>

                        <div class="text-center col w-80 border border-dark">
                            <strong>Datos del Beneficiario:</strong>
                        </div>

                        <div class="text-right">
                            <p style="font-size: 14px;">
                                <b>Nombre:</b> <span t-field="o.partner_id.name"/><br/>
                                <b>RIF:</b> <span t-field="o.partner_id.vat"/><br/>
                                <b>RIM:</b> <span t-esc="o.partner_id.RIM or 'N/A'"/><br/>
                                <b>RIM:</b> <span t-esc="o.partner_id.economy_activiy or 'N/A'"/><br/>
                                <b>Teléfono:</b> <span t-field="o.partner_id.phone"/><br/>
                                <b>Dirección:</b> <span t-field="o.partner_id.street"/>
                            </p>
                        </div>

                        <div class="text-center col w-80 border border-dark">
                            <strong>Datos de la Retención:</strong>
                        </div>
                        <br/>

                        <div class="text-right">
                            <table class="table table-sm o_main_table">
                                <thead>
                                    <tr>
                                        <th class="text-center" colspan="2"><strong>Datos de la retención practicada</strong></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td class="text-right"><b>Por Concepto:</b></td>
                                        <td class="text-left"><span>RET. IMP. MUNICIPAL 1%</span></td>
                                    </tr>
                                    <tr>
                                        <td class="text-right"><b>Factura N°:</b></td>
                                        <td class="text-left">
                                            <t t-if="o.move_id.move_type == 'out_invoice'">
                                                <span t-esc="o.move_id.name"/>
                                            </t>
                                            <t t-else="">
                                                <span t-esc="o.move_id.supplier_invoice_number"/>
                                            </t>
                                        </td>
                                        <td class="text-right"></td>
                                    </tr>
                                    <tr>
                                        <td class="text-right"><b>N° de Control:</b></td>
                                        <td class="text-left">
                                            <t><span t-esc="o.move_id.correlative"/></t>
                                        </td>
                                        <td class="text-right"></td>
                                    </tr>
                                    <tr>
                                        <td class="text-right"><b>Fecha de Factura:</b></td>
                                        <td class="text-left"><span t-esc="o.move_id.invoice_date.strftime('%d/%m/%Y')"/></td>
                                    </tr>
                                    <tr>
                                        <td class="text-right"><b>Base Imponible:</b></td>
                                        <td class="text-left">
                                            <t t-if="o.move_id.currency_id.name == 'VEF'">
                                                <span t-esc="'{0:,.2f}'.format(o.move_id.amount_untaxed).replace(',', '#').replace('.', ',').replace('#', '.')"/> Bs.
                                            </t>
                                            <t t-if="o.move_id.currency_id.name == 'USD'">
                                                <span t-esc="'{0:,.2f}'.format(o.move_id.amount_untaxed_bs).replace(',', '#').replace('.', ',').replace('#', '.')"/> Bs.
                                            </t>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="text-right"><b>Importe de la Retención:</b></td>
                                        <td class="text-left">
                                            <span t-esc="'{0:,.2f}'.format(o.amount).replace(',', '#').replace('.', ',').replace('#', '.')"/> Bs.
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                        <br/>

                        <div class="row">
                            <div class="col-2"/>
                            <div name="footer_left_column" class="col-4">
                                ________________________ <br/>
                                Agente de Retención
                            </div>
                            <div class="col-2"/>
                            <div name="footer_right_column" class="col-4">
                                _______________________<br/>
                                Beneficiario
                            </div>
                        </div>

                        <div class="text-center" style="margin-top:100px;">
                            <p class="text-center" style="font-size: 10px;">
                                Según Ordenanza Sobre licencia e impuesto a las Actividades Económicas, Comerciales, Industriales, 
                                De Servicio y De índole Similar en el Municipio Maracaibo del Estado Zulia, Gaceta Municipal N° . 
                                276-2020 Art. 69 al 90 de fecha 01-10-2020 DECRETO N° 0031-2020 21-04-2020 N° 075-2020 Alcaldía 
                                Bolivariana del Municipio Maracaibo Estado Zulia.
                            </p>
                        </div>
                    </div>
                </t>
            </main>
        </t>
    </template>
</odoo>
