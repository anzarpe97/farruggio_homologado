<odoo>
    <!-- Acción de ventana para Retenciones Municipales -->
    <record id="action_account_wh_municipal" model="ir.actions.act_window">
        <field name="name">Retenciones Municipales</field>
        <field name="res_model">account.wh.municipal</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p>
                Aquí puedes ver todas las retenciones municipales generadas para facturas de compra.
            </p>
        </field>
    </record>

    <!-- Vistas -->
    <record id="view_account_wh_municipal_form" model="ir.ui.view">
        <field name="name">account.wh.municipal.form</field>
        <field name="model">account.wh.municipal</field>
        <field name="arch" type="xml">
            <form string="Retención Municipal">
                <header>
                    <button name="confirm_check" states="draft" type="object" string="Confirmar"/>
                    <button name="action_cancel" states="confirmed,draft,done" type="object" string="Cancelar" />
                    <button name="print_report_account_wh_municipal" string="Imprimir Comprobante" type="object" class="btn-primary" states="confirmed,done"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,done" statusbar_colors="{&quot;confirmed&quot;:&quot;blue&quot;}"/>
                </header>
                <sheet>
                    <group>
                        <field name="move_id" readonly="1"/>
                        <field name="partner_id"/>
                        <field name="move_type" invisible="1"/>
                        <field name="journal_id" readonly="1" force_save="1" options="{'no_open': True, 'no_quick_create': True, 'no_create_edit' : True}"/>
                        <field name="municipal_number_asignado"
                                attrs="{
                                    'readonly': [
                                        '|',
                                        ('move_type', 'in', ['in_invoice', 'in_refund']),
                                        ('state', 'in', ['confirmed', 'done'])
                                    ],
                                    'required': [('move_type', 'in', ['out_invoice', 'out_refund'])]
                                }"/>
                        <field name="date" readonly="1"/>
                        <field name="state" invisible="1"/>
                    </group>
                    <sheet>
                        <group string="Datos de la Retención:" colspan="4" style="width: 100%;">
                            <div style="display: flex; flex-direction: column; width: 100%;">
                                <span style="display: block; width: 100%; white-space: nowrap;">
                                    Porcentaje de Retención: 1%
                                </span>
                                <span style="display: block; width: 100%; white-space: nowrap;">
                                    Importe: <field name="amount" widget="monetary"/>
                                </span>
                            </div>
                        </group>
                    </sheet>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_account_wh_municipal_tree" model="ir.ui.view">
        <field name="name">account.wh.municipal.tree</field>
        <field name="model">account.wh.municipal</field>
        <field name="arch" type="xml">
            <tree string="Retenciones Municipales">
                <field name="name"/>
                <field name="date"/>
                <field name="partner_id"/>
                <field name="move_id"/>
                <field name="amount"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <!-- Vista de búsqueda (search view) DEBE estar antes de las acciones que la referencian -->
    <record id="view_account_wh_municipal_filter" model="ir.ui.view">
        <field name="name">account.wh.municipal.search</field>
        <field name="model">account.wh.municipal</field>
        <field name="arch" type="xml">
            <search string="Buscar Retenciones Municipales">
                <group>
                    <filter name="draft" string="Borrador" domain="[('state','=','draft')]"/>
                    <filter name="confirmed" string="Confirmado" domain="[('state','=','confirmed')]"/>
                    <filter name="done" string="Publicado" domain="[('state','=','done')]"/>
                    <filter name="cancel" string="Cancelado" domain="[('state','=','cancel')]"/>
                </group>
                <group expand="1" string="Agrupar por...">
                    <filter string="Proveedor/Cliente" name="partner" domain="[]" context="{'group_by':'partner_id'}"/>
                    <filter string="Estado" name="state" domain="[]" context="{'group_by':'state'}"/>
                    <filter string="Fecha" name="date" domain="[]" context="{'group_by':'date'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Acción: Retención Municipal a Proveedor -->
    <record id="action_account_wh_municipal_supplier" model="ir.actions.act_window">
        <field name="name">Retención Municipal al Proveedor</field>
        <field name="res_model">account.wh.municipal</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('move_id.move_type','in',['in_invoice','in_refund'])]</field>
        <field name="context">{}</field>
        <field name="search_view_id" ref="view_account_wh_municipal_filter"/>
    </record>

    <!-- Acción: Retención Municipal al Cliente -->
    <record id="action_account_wh_municipal_customer" model="ir.actions.act_window">
        <field name="name">Retención Municipal al Cliente</field>
        <field name="res_model">account.wh.municipal</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('move_id.move_type','in',['out_invoice','out_refund'])]</field>
        <field name="context">{}</field>
        <field name="search_view_id" ref="view_account_wh_municipal_filter"/>
    </record>

    <!-- Menú principal -->
    <menuitem id="menu_account_wh_municipal"
              name="Retenciones Municipales"
              parent="account.menu_finance"
              action="action_account_wh_municipal"/>

    <!-- Menú: Retenciones Municipales al Proveedor -->
    <menuitem id="menu_account_wh_municipal_supplier"
            name="Retención Municipal al Proveedor"
            parent="account.menu_finance_payables"
            action="action_account_wh_municipal_supplier"/>

    <!-- Menú: Retenciones Municipales al Cliente -->
    <menuitem id="menu_account_wh_municipal_customer"
            name="Retención Municipal al Cliente"
            parent="account.menu_finance_receivables"
            action="action_account_wh_municipal_customer"/>
</odoo>
