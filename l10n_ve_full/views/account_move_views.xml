<odoo>
  <record id="view_move_form_inherit_public_company" model="ir.ui.view">
    <field name="name">account.move.form.public.company</field>
    <field name="model">account.move</field>
    <field name="inherit_id" ref="account.view_move_form"/>
    <field name="arch" type="xml">
      <xpath expr="//field[@name='partner_id']" position="after">
        <field name="is_public_company" attrs="{'invisible': [('move_type','not in',('out_invoice','out_refund'))]}" string="¿Factura de empresa pública? (Marque si corresponde)"/>
      </xpath>
    </field>
  </record>
</odoo>
