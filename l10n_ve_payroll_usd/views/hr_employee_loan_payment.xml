<odoo>
    <record id="view_loan_payment_tree" model="ir.ui.view">
        <field name="name">loan.payment.tree</field>
        <field name="model">hr.employee.loan.payment</field>
        <field name="arch" type="xml">
            <tree>
                <field name="loan_id"/>
                <field name="date"/>
                <field name="amount"/>
                <field name="state"/> <!-- Nuevo campo para mostrar el estado -->
                <field name="move_id"/>
            </tree>
        </field>
    </record>

    <record id="view_loan_payment_form" model="ir.ui.view">
        <field name="name">loan.payment.form</field>
        <field name="model">hr.employee.loan.payment</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="loan_id" readonly="1"/>
                        <field name="date"/>
                        <field name="amount"/>
                        <field name="note"/>
                        <field name="state" readonly="1"/> <!-- Mostrar el estado en modo solo lectura -->
                        <field name="move_id" readonly="1"/>
                    </group>
                        <!-- Mostrar el botón solo si el estado es 'draft' -->
                        <button string="Registrar Abono"
                                type="object"
                                name="post_payment"
                                class="btn-primary"
                                attrs="{'invisible': [('state', '!=', 'draft')]}"/>
                        <!-- El botón eliminar también se oculta si ya está registrado -->
                        <button string="Cancelar"
                                type="object"
                                name="unlink"
                                class="btn-secondary"
                                attrs="{'invisible': [('state', '!=', 'draft')]}"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_loan_payment_tree" model="ir.actions.act_window">
        <field name="name">Abonos de Préstamo</field>
        <field name="res_model">hr.employee.loan.payment</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'default_loan_id': active_id}</field>
    </record>
</odoo>
