<odoo>
    <template id="report_cxc_template">
        <t t-call="web.external_layout">
            <div class="page">
                <h2 style="text-align: center;">Reporte de Cuentas por Cobrar</h2>
                <p><strong>Compañía:</strong> <t t-esc="report_data.get('company', 'Sin Compañía')"/></p>
                <p><strong>Periodo:</strong> <t t-esc="data['start_date']"/> - <t t-esc="data['end_date']"/></p>
                
                <table class="table table-bordered">
                    <thead>
                        <tr>
                            <th>Cliente</th>
                            <t t-foreach="data['periods']" t-as="period">
                                <th t-esc="period['name']"/>
                            </t>
                            <th>Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="data['partners']" t-as="partner">
                            <tr>
                                <td t-esc="partner['name']"/>
                                <t t-foreach="data['periods']" t-as="period">
                                    <td t-esc="format(partner['periods'][period['name']], '.2f')"/>
                                </t>
                                <td t-esc="format(partner['total'], '.2f')"/>
                            </tr>
                        </t>
                    </tbody>
                </table>
            </div>
        </t>
    </template>
</odoo>
