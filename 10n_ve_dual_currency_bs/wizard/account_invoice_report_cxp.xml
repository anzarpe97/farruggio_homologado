<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <data>

        <record id="account_invoice_report_cxp_report_wizard" model="ir.ui.view">
            <field name="name">account.invoice.report.cxp</field>
            <field name="model">account.invoice.report.cxp</field>
            <field name="arch" type="xml">
                <form string="Reporte de cuentas por Pagar">
                    <field name="state" invisible="1"/>
                    
                    <group states="choose">
                        <group>
                            <field name="start_date" />
                            <field name="end_date"/>
                        </group>
                        <group>
                            <field name="report_format" widget="selection"/>
                        </group>
                        <group>
                            <field name="partner_id" domain="[('customer_rank', '>', 0)]"/>
                            <field name="due_range_ids" widget="many2many_tags" options="{'no_create': True}"/>
                        </group>
                    </group>

                    <group states="get">
                        <group>
                            <field name="invoice_data" colspan="4" invisible="1"/>
                            <field name="file_name_pdf" filename="invoice_data" colspan="4" attrs="{'invisible': [('report_format', '!=', 'pdf')]}"/>
                        </group>
                    </group>

                    <footer states="choose">
                        <button string="Generar Reporte"
                            class="btn-primary"
                            name="action_generate_report"
                            type="object"/>
                        <button string="Cancelar"
                            class="btn-default"
                            special="cancel"/>
                    </footer>

                    <footer states="get">
                        <button special="cancel" string="Cerrar" class="oe_highlight" />
                    </footer>
                </form>
            </field>
        </record>

        
        <record id="action_report_cxp_xls" model="ir.actions.act_window">
            <field name="name">Reporte Cuentas Por Pagar</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">account.invoice.report.cxp</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="account_invoice_report_cxp_report_wizard"/>
            <field name="domain">[]</field>
            <field name="context">{}</field>
            <field name="target">new</field>
        </record>

        <menuitem 
            name = "Cuentas por Pagar"
            action="action_report_cxp_xls" 
            id="menu_action_report_cxp_xls"
            parent="dual_fiance_menu_categ"
            sequence="76"/>

    </data>
</odoo>