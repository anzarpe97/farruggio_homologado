<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <data>

        <record id="account_invoice_report_cxc_report_wizard" model="ir.ui.view">
            <field name="name">account.invoice.report.cxc</field>
            <field name="model">account.invoice.report.cxc</field>
            <field name="arch" type="xml">
                <form string="Reporte de cuentas por cobrar">
                    <field name="state" invisible="1"/>
                    
                    <group states="choose">
                        <group>
                            <field name="start_date" />
                            <field name="end_date"/>
                        </group>
                        <group>
                            <field name="report_format" widget="selection"/>
                        </group>
                        <group>
                            <field name="user_id" domain="[('share', '=', False)]"/>  <!-- Filtrar solo usuarios internos -->
                            <field name="partner_id" domain="[('customer_rank', '>', 0)]"/>  <!-- Filtra solo clientes -->
                            <field name="due_range_ids" widget="many2many_tags"/>  <!-- Filtro de vencimientos -->
                        </group>
                    </group>

                    <group states="get">
                        <group>
                            <field name="invoice_data" colspan="4" invisible="1"/>
                            <field name="file_name_pdf" filename="invoice_data" colspan="4" attrs="{'invisible': [('report_format', '!=', 'pdf')]}"/>
                            <field name="file_name_excel" filename="invoice_data" colspan="4" attrs="{'invisible': [('report_format', '!=', 'excel')]}"/>
                        </group>
                    </group>

                    <footer states="choose">
                        <button string="Generar Reporte"
                            class="btn-primary"
                            name="action_generate_report"
                            type="object"/>
                        <button string="Cancelar"
                            class="btn-default"
                            special="cancel"/>
                    </footer>

                    <footer states="get">
                        <button special="cancel" string="Cerrar" class="oe_highlight" />
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_report_cxc" model="ir.actions.act_window">
            <field name="name">Reporte Cuentas Por Cobrar</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">account.invoice.report.cxc</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="account_invoice_report_cxc_report_wizard"/>
            <field name="domain">[]</field>
            <field name="context">{}</field>
            <field name="target">new</field>
        </record>

        <menuitem 
            name="Cuentas por Cobrar"
            action="action_report_cxc" 
            id="menu_action_report_cxc"
            parent="dual_fiance_menu_categ"
            sequence="75"/>

    </data>
</odoo>
