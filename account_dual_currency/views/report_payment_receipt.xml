<odoo>
    <!-- Coletilla IGTF -->
    <template id="report_payment_receipt_document_custom" inherit_id="account.report_payment_receipt_document">
        <xpath expr="//div[@class='page']" position="inside">
            <t t-if="o.aplicar_igtf_divisa">
                <p style="margin-top: 20px; font-size: 13px;">
                    <t t-if="o.journal_igtf_id.currency_id.name == 'VEF' and o.tax_today">
                        Este pago ha generado un recargo de IGTF por un importe de:
                        <strong><span t-esc="round(o.mount_igtf * o.tax_today, 2)"/> Bs.</strong>
                        sobre una Base Imponible de:
                        <strong><span t-esc="round(o.amount * o.tax_today, 2)"/> Bs.</strong>.
                    </t>
                    <t t-else="1">
                        Este pago ha generado un recargo de IGTF por un importe de:
                        <strong><span t-field="o.mount_igtf" t-options="{'widget': 'monetary', 'display_currency': o.currency_id, 'noSymbol': True}"/></strong>
                        sobre una Base Imponible de:
                        <strong><span t-field="o.amount" t-options="{'widget': 'monetary', 'display_currency': o.currency_id, 'noSymbol': True}"/></strong>.
                    </t>
                </p>
            </t>
            <p style="margin-top: 15px; text-align: center; font-weight: bold; font-size: 12px;">
                DOCUMENTO NO FISCAL
            </p>
        </xpath>
    </template>
    
    <!-- Reemplazo de tabla para eliminar columnas innecesarias -->
    <template id="report_payment_receipt_document_rebuild_table" inherit_id="account.report_payment_receipt_document">
        <xpath expr="//table[@class='table table-sm']" position="replace">
            <table class="table table-sm" style="width: 100%;">
                <thead>
                    <tr>
                        <th>Fecha de factura</th>
                        <th>Número de factura</th>
                        <th class="text-end">Importe</th>
                    </tr>
                </thead>
                <tbody>
                    <t t-set="invoices" t-value="o.reconciled_invoice_ids or o.reconciled_bill_ids"/>
                    <t t-foreach="invoices" t-as="inv">
                        <t t-if="inv.move_type != 'entry'">
                            <!-- Fila de factura -->
                            <tr>
                                <td><span t-field="inv.invoice_date"/></td>
                                <td><span t-field="inv.name"/></td>
                                <td class="text-end"><span t-field="inv.amount_total"/></td>
                            </tr>
                            <!-- Fila(s) de pago -->
                            <tr t-foreach="inv._get_reconciled_invoices_partials()[0]" t-as="par">
                                <t t-set="payment" t-value="par[2]"/>
                                <t t-set="amountInvoice" t-value="-par[1]"/>
                                <td><span t-field="payment.move_id.date"/></td>
                                <td><span t-field="payment.move_id.name"/></td>
                                <td class="text-end">
                                    <span t-esc="amountInvoice" t-options="{'widget': 'monetary', 'display_currency': inv.currency_id}"/>
                                </td>
                            </tr>
                            <!-- Fila de saldo -->
                            <tr>
                                <td colspan="2"><strong>Importe adeudado para <span t-field="inv.name"/></strong></td>
                                <td class="text-end"><strong><span t-field="inv.amount_residual"/></strong></td>
                            </tr>
                        </t>
                    </t>
                </tbody>
            </table>
        </xpath>
    </template>
</odoo>
