<?xml version="1.0" encoding="utf-8"?>
<odoo >

    <record id="account_payment_method_in_withholding" model="account.payment.method">
        <field name="name">Retencion Iva</field>
        <field name="code">withholding</field>
        <field name="payment_type">inbound</field>
    </record>

    <record id="account_payment_method_out_withholding" model="account.payment.method">
        <field name="name">Retencion ISLR</field>
        <field name="code">withholding</field>
        <field name="payment_type">outbound</field>
    </record>

    <record id="account_payment_method_line_in_withholding" model="account.payment.method.line">
        <field name="payment_method_id" ref="account_payment_method_in_withholding" />
    </record>
    <record id="account_payment_method_line_out_withholding" model="account.payment.method.line">
        <field name="payment_method_id" ref="account_payment_method_out_withholding" />
    </record>
    <record id="account_payment_method_line_out2_withholding" model="account.payment.method.line">
        <field name="payment_method_id" ref="account_payment_method_out_withholding" />
    </record>



</odoo>
