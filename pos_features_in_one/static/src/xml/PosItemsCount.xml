<?xml version="1.0" encoding="utf-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="ItemsCount" owl="1">
        <t t-if="env.pos.config.show_product_total_quantity">

        <!--    Showing total items    -->
            <div class="control-button">
           <div>
               <span> </span>
               <span>
                   <i class="fa fa-list-ul"/>
                   Total Items:
                   <t t-esc="get_items_count()"/>
               </span>
           </div>
       </div>
            <!--    Shows the total quantity of products inside the numpad    -->
            <div class="control-button">
            <i class="fa fa-fw fa-shopping-cart"/>
                <span style="text-align:right">Total Qty:
                    <t t-esc="get_items_qty()"/>
               </span>
        </div>
        </t>
   </t>
</templates>