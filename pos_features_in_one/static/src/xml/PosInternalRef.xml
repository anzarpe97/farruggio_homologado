<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-inherit="point_of_sale.ProductItem" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('product-name')]" position="before">
            <t t-if="env.pos.config.pos_show_internal_ref">
            <span class="int_reference" style="box-sizing: border-box;
    line-height: 14px;
    overflow: hidden;
        margin: 0.2rem 0.5rem 0 0.5rem;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    color: #a8a8a8; ">
                [<t t-esc="props.product.default_code" />]
            </span>
            </t>
        </xpath>
        <xpath expr="//div[hasclass('product-content')]/div[1]" position="after">
            <t t-if="env.pos.config.pos_show_barcode">
                <div class="product-name"><t t-if="props.product.barcode" t-esc="props.product.barcode"/></div>
            </t>
        </xpath>
    </t>
</templates>
