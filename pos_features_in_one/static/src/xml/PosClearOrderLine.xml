<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" inherit_id="point_of_sale_template" xml:space="preserve">
    <t t-inherit="point_of_sale.Orderline" t-inherit-mode="extension" owl="1">
        <xpath expr="//span[hasclass('price')]" position="inside">
            <t t-if="env.pos.config.delete_pos_orderline_all_cart">
<!--            <i class="fa fa-trash-o" t-on-click="clear_button_fun" aria-hidden="true" style="display:contents; font-size:medium;"></i>-->
            <i id="clear_icon" class="fa fa-times-circle" t-on-click="clear_button_fun"/>
            </t>
        </xpath>
    </t>
</templates>