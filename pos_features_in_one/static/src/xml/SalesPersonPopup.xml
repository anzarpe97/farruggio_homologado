<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" inherit_id="point_of_sale.template">

    <t t-name="SalespersonPopup" owl="1">
        <div role="dialog" class="modal-dialog">
            <Draggable>
                <div class="popup">
                    <header class="title drag-handle">
                        <t t-esc="props.title" />
                    </header>
                    <div style="display: inline-flex;padding: 20px;">
                        <div style="padding-top: 10px;">Vendedor: </div>
                        <div>
                            <input list="emp_list" id="empID" t-on-change="onChangeSalesperson"/>
                            <datalist id="emp_list">
                                <t t-foreach="env.pos.employees" t-as="item"  t-key ="item.id" t-att-data-product-id="item.id">
                                    <option t-att-value="item.name" t-att-id="item.id"/>
                                </t>
                            </datalist>
                        </div>
                    </div>
                    <footer class="footer">
                        <div class="button confirm" t-on-click="confirm" style="background: #6EC89B;border-color: #6EC89B;color:white;">
                            Añadir
                        </div>
                        <div class="button cancel" t-on-click="cancel">
                            <t t-esc="props.cancelText" />
                        </div>
                    </footer>
                </div>
            </Draggable>
        </div>
    </t>

</templates>