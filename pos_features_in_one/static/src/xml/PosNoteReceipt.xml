<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="OrderReceipt" t-inherit="point_of_sale.OrderReceipt" t-inherit-mode="extension" owl="1">
        <xpath expr="//div[hasclass('after-footer')]" position="after">
            <t t-if="env.pos.config.pos_display_note_in_receipt">
                <t t-if="props.order.get_order_order_note()">
                    <br />
                    <div style="text-align: left;">
                        <span style="font-weight: bold;">Note:
                        <t t-esc="props.order.get_order_order_note()" /></span>
                    </div>
                </t>
            </t>
        </xpath>
    </t>

</templates>
