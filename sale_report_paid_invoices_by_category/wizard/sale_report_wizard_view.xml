<odoo>
    <record id="view_sale_report_wizard" model="ir.ui.view">
        <field name="name">sale.report.wizard</field>
        <field name="model">sale.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Reporte de Facturas Pagadas">
                <group>
                    <field name="date_from"/>
                    <field name="date_to"/>
                    <field name="user_id"/>
                </group>
                <footer>
                    <button string="Generar Reporte" type="object" name="generate_report" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <act_window id="action_sale_report_wizard"
                name="Reporte de Facturas Pagadas"
                res_model="sale.report.wizard"
                view_mode="form"
                target="new"
                view_id="view_sale_report_wizard"/>

    <menuitem id="menu_sale_report_root"
              name="Reporte de Facturas Pagadas"
              parent="sale.menu_sale_order"
              action="action_sale_report_wizard"
              sequence="99"/>
</odoo>
