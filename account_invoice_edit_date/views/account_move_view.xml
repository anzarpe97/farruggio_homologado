<odoo>
    <record id="view_move_form_inherit_edit_date_field" model="ir.ui.view">
        <field name="name">account.move.form.inherit.editable_date</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="before">
                <field name="editable_date"
                    string="Editar Fecha Contable"
                    attrs="{'invisible': ['|', ('state', '!=', 'posted'), ('move_type', '!=', 'in_invoice')]}"/>
            </xpath>
        </field>
    </record>
</odoo>
