<odoo>
    <data noupdate="0">
        <!-- Grupo Analista de Cuentas por Cobrar -->
        <record id="group_cxc_analyst" model="res.groups">
            <field name="name">Analista de Cuentas por Cobrar</field>
            <field name="category_id" ref="base.module_category_accounting"/>
        </record>

        <!-- Regla: Ejecutivos solo ven sus propios pagos -->
        <record id="informative_payment_own_documents_rule" model="ir.rule">
            <field name="name">Pagos informativos propios</field>
            <field name="model_id" ref="model_informative_payment"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Regla: Analista de CxC ve todos los pagos -->
        <record id="informative_payment_cxc_analyst_rule" model="ir.rule">
            <field name="name">Pagos informativos - Analista CxC</field>
            <field name="model_id" ref="model_informative_payment"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('informative_customer_payments.group_cxc_analyst'))]"/>
        </record>

        <!-- Nuevo grupo: Analista de CxC Sin Notificaciones -->
        <record id="group_cxc_analyst_no_notify" model="res.groups">
            <field name="name">Analista de Cuentas por Cobrar (Sin Notificaciones)</field>
            <field name="category_id" ref="base.module_category_accounting"/>
        </record>

        <!-- Regla: Analista de CxC Sin Notificaciones ve todos los pagos -->
        <record id="informative_payment_cxc_analyst_no_notify_rule" model="ir.rule">
            <field name="name">Pagos informativos - Analista CxC (Sin Notificaciones)</field>
            <field name="model_id" ref="model_informative_payment"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('informative_customer_payments.group_cxc_analyst_no_notify'))]"/>
        </record>
    </data>
</odoo>
