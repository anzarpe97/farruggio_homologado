<odoo>
    <record id="view_form_informative_payment" model="ir.ui.view">
        <field name="name">informative.payment.form</field>
        <field name="model">informative.payment</field>
        <field name="arch" type="xml">
            <form string="Pago Informativo de Cliente">
            <header>
                <button name="action_confirm" type="object" string="Confirmar" class="btn-primary"
                        attrs="{'invisible': [('state', '!=', 'draft')]}"/>
                <button name="action_related" type="object" string="Relacionado" class="btn-success"
                        groups="informative_customer_payments.group_cxc_analyst"
                        attrs="{'invisible': [('state', '!=', 'confirmed')]}"/>
                <button name="action_cancel"
                        string="Anulado"
                        type="object"
                        class="btn-secondary"
                        groups="informative_customer_payments.group_cxc_analyst"
                        attrs="{'invisible': [('state', 'in', ['draft', 'related'])]}"/>
                <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,related,related"/>
            </header>
                <sheet>
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="partner_id" attrs="{'readonly': [('state', '!=', 'draft')], 'required': [('state', '=', 'draft')]}"/>
                        <field name="payment_type" attrs="{'readonly': [('state', '!=', 'draft')], 'required': [('state', '=', 'draft')]}"/>
                        <field name="date" attrs="{'readonly': [('state', '!=', 'draft')], 'required': [('state', '=', 'draft')]}"/>
                        <field name="amount" attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                        <field name="currency_id" attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                        <field name="invoice_ids"
                                widget="many2many_tags"
                                options="{'no_create': True}"
                                attrs="{'readonly': [('state', '!=', 'draft')], 'required': [('payment_type', '=', 'factura')]}"/>
                        <field name="banco" attrs="{'readonly': [('state', '!=', 'draft')], 'required': [('state', '=', 'draft')]}"/>
                        <field name="payment_method" attrs="{'readonly': [('state', '!=', 'draft')], 'required': [('state', '=', 'draft')]}"/>
                        <field name="note" attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                        <field name="user_id" readonly="1"/>
                        <field name="attachment_ids" widget="many2many_binary"
                                context="{
                                    'default_res_model': 'informative.payment',
                                    'default_res_id': active_id
                                }"
                                attrs="{'readonly': [('state', 'in', ['confirmed', 'related', 'anulado'])]}"/>
                    </group>
                </sheet>

                <field name="message_attachment_count" invisible="1"/>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                    <field name="message_attachment_count"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_kanban_informative_payment" model="ir.ui.view">
        <field name="name">informative.payment.kanban</field>
        <field name="model">informative.payment</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="partner_id"/>
                <field name="amount"/>
                <field name="currency_id"/>
                <field name="date"/>
                <templates>
                    <t t-name="kanban-box">
                         <div t-attf-class="oe_kanban_card oe_kanban_global_click" t-att-data-id="record.id">
                            <strong><field name="partner_id"/></strong><br/>
                            <span><field name="amount"/> <field name="currency_id"/></span><br/>
                            <span><field name="date"/></span>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_tree_informative_payment" model="ir.ui.view">
        <field name="name">informative.payment.tree</field>
        <field name="model">informative.payment</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="amount"/>
                <field name="currency_id"/>
                <field name="date"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="action_informative_payment" model="ir.actions.act_window">
        <field name="name">Pagos Informativos</field>
        <field name="res_model">informative.payment</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_informative_payment_root" name="Informe de Pagos" sequence="10" web_icon="informative_customer_payments,static/description/registro_pagos.png"/>
    <menuitem id="menu_informative_payment" name="Pagos" parent="menu_informative_payment_root" action="action_informative_payment"/>

    <record id="view_kanban_account_move_custom" model="ir.ui.view">
        <field name="name">account.move.kanban.custom</field>
        <field name="model">account.move</field>
        <field name="priority" eval="1"/>
        <field name="arch" type="xml">
        <kanban>
            <field name="partner_id"/>
            <field name="amount_total"/>
            <field name="amount_total_usd"/>
            <field name="name"/>
            <field name="invoice_date"/>
            <templates>
                <t t-name="kanban-box">
                    <div t-attf-class="oe_kanban_card oe_kanban_global_click" t-att-data-id="record.id">
                        <strong>
                            <field name="name"/>
                        </strong><br/>
                        <strong>Cliente: <field name="partner_id"/></strong><br/>
                        <span>Total Bs: <field name="amount_total"/></span><br/>
                        <span>Total USD: <field name="amount_total_usd"/></span><br/>
                        <span>Monto Adeudado USD: <field name="amount_residual_usd"/></span><br/>
                        <span>Fecha de factura: <field name="invoice_date"/></span>
                        <br/>
                        <!-- <span>
                            Asiento contable: <t t-esc="record.id"/>
                        </span> -->
                    </div>
                </t>
            </templates>
        </kanban>
    </field>
    </record>
</odoo>
