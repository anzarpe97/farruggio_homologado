        <field name="usage">ir_actions_server</field>
        <field name="code">
            if records:
                records.action_approve_selected_invoices()
        </field>
    </record> -->


    <!-- Acción server para aprobar varias facturas desde la lista -->
    <record id="action_approve_selected_invoices" model="ir.actions.server">
        <field name="name">Aprobar Facturas</field>
        <field name="model_id" ref="account.model_account_move"/>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_view_types">list</field>
        <field name="groups_id" eval="[(4, ref('account_invoice_approval.group_invoice_approver'))]"/>
        <field name="state">code</field>
        <field name="code">
            for invoice in records.filtered(lambda x: x.move_type == 'in_invoice' and not x.x_aprobada):
                invoice.action_approve_invoice()
        </field>
    </record>

</odoo>
