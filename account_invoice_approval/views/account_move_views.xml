<odoo>
    <!-- Vista árbol para facturas aprobadas de proveedor -->
    <record id="view_account_move_tree_approved" model="ir.ui.view">
        <field name="name">account.move.tree.approved</field>
        <field name="model">account.move</field>
        <field name="arch" type="xml">
            <tree string="Facturas Aprobadas" multi_edit="1" decoration-success="x_aprobada">
                <field name="x_aprobada" invisible="1"/>
                <field name="move_type" invisible="1"/>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="company_id" invisible="1"/>
                <field name="invoice_date"/>
                <field name="amount_total"/>
                <field name="currency_id"/>
                <field name="payment_state"/>
                <field name="state"/>
                <field name="x_aprobada_text" attrs="{'invisible': [('move_type', '!=', 'in_invoice')]}"/>
            </tree>
        </field>
    </record>


    <!-- Herencia del formulario: insignia "Aprobada" + botón de aprobación -->
    <record id="view_account_move_form_aprobada" model="ir.ui.view">
        <field name="name">account.move.form.x.aprobada</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <!-- Campo e insignia SOLO para facturas de proveedor -->
            <xpath expr="//field[@name='state']" position="after">
                <field name="x_aprobada" invisible="1"/>
                <field name="x_aprobada_text"
                       widget="badge"
                       options="{'class': 'oe_badge_success'}"
                       attrs="{
                           'invisible': [
                               '|',
                               ('x_aprobada', '=', False),
                               ('move_type', '!=', 'in_invoice')
                           ]
                       }"/>
            </xpath>

            <!-- Botón "Aprobar Factura" SOLO en facturas proveedor no aprobadas -->
            <xpath expr="//header//button[last()]" position="after">
                <button 
                    name="action_approve_invoice" 
                    string="Aprobar Factura" 
                    type="object" 
                    class="oe_highlight"
                    groups="account_invoice_approval.group_invoice_approver"
                    attrs="{
                        'invisible': [
                            '|', '|', '|',
                            ('x_aprobada', '=', True),
                            ('state', '!=', 'posted'),
                            ('move_type', '!=', 'in_invoice'),
                            ('move_type', '=', False)
                        ]
                    }"/>
            </xpath>

        </field>
    </record>
    
