<odoo>
    <record id="view_move_form_custom_cost" model="ir.ui.view">
        <field name="name">stock.move.form.custom.cost</field>
        <field name="model">stock.move</field>
        <field name="inherit_id" ref="stock.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/group" position="inside">
                <field name="picking_type_code" inivisible="1"/>
                <field name="custom_cost_usd"
                        attrs="{'invisible': [('picking_type_code', '!=', 'incoming')]}"/>
            </xpath>
        </field>
    </record>
</odoo>
