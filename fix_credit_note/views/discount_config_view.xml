<odoo>
    <!-- Tus vistas y acción existentes -->
    <record id="view_discount_config_tree" model="ir.ui.view">
        <field name="name">discount.config.tree</field>
        <field name="model">discount.config</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="discount_type"/>
                <field name="apply_to"/>
                <field name="discount_percent"/>
            </tree>
        </field>
    </record>

    <record id="view_discount_config_form" model="ir.ui.view">
        <field name="name">discount.config.form</field>
        <field name="model">discount.config</field>
        <field name="arch" type="xml">
            <form string="Configuración de Descuento">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="discount_type"/>
                        <field name="early_payment_days" attrs="{'invisible': [('discount_type', '!=', 'early_payment')]}"/>
                        <field name="currency_payment"/>
                        <field name="apply_to"/>
                        <field name="discount_percent"/>
                    </group>
                    <group attrs="{'invisible': [('apply_to', '!=', 'customers')]}">
                        <field name="partner_ids" widget="many2many_tags"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- VISTA DE BÚSQUEDA -->
    <record id="view_discount_config_search" model="ir.ui.view">
        <field name="name">discount.config.search</field>
        <field name="model">discount.config</field>
        <field name="arch" type="xml">
            <search string="Buscar Configuración de Descuentos">
                <field name="name"/>
                <field name="partner_ids"/>

                <!-- Filtros por tipo de descuento -->
                <filter string="Por Negociación" name="filter_negotiation"
                        domain="[('discount_type', '=', 'negotiation')]"/>
                <filter string="Por Pronto Pago" name="filter_early_payment"
                        domain="[('discount_type', '=', 'early_payment')]"/>
                
                <separator/>

                <!-- Filtros por moneda -->
                <filter string="VEF" name="filter_vef"
                        domain="[('currency_payment', '=', 'vef')]"/>
                <filter string="USD" name="filter_usd"
                        domain="[('currency_payment', '=', 'usd')]"/>
                <filter string="Cualquiera" name="filter_any"
                        domain="[('currency_payment', '=', 'any')]"/>
            </search>
        </field>
    </record>


    <record id="action_discount_config" model="ir.actions.act_window">
        <field name="name">Configuración de Descuentos</field>
        <field name="res_model">discount.config</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- MENÚ EN FACTURACIÓN PRINCIPAL - ESTO SÍ FUNCIONAx2 -->
    <menuitem id="menu_discount_config_root"
              name="Configuración de Descuentos"
              parent="account.menu_finance_configuration"
              action="action_discount_config"
              sequence="50"
              groups="base.group_user"/>
</odoo>