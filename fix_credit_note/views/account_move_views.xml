<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_move_form_inherit_add_credit_note" model="ir.ui.view">
        <field name="name">account.move.form.inherit.add.credit.note</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <header>
                <!-- Agregamos el botón en el header -->
                <button name="action_add_credit_note"
                        string="Añadir Nota de Crédito"
                        type="object"
                        class="btn-secondary"
                        attrs="{'invisible': ['|', ('state', '!=', 'posted'), ('move_type', 'not in', ['out_invoice', 'in_invoice'])]}"/>
            </header>
        </field>
    </record>
</odoo>
