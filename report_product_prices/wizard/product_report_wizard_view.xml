<odoo>
<record id="view_product_report_wizard_form" model="ir.ui.view">
    <field name="name">product.report.wizard.form</field>
    <field name="model">product.report.wizard</field>
    <field name="arch" type="xml">
      <form string="Reporte de Productos">
        <group>
          <field name="date_start"/>
          <field name="date_end"/>
          <field name="user_id"/>
          <field name="partner_id"/>
        </group>
        <footer>
          <button name="action_export_excel" string="Exportar a Excel"
                  type="object" class="btn-primary"/>
          <button name="action_export_pdf" string="Exportar a PDF"
                  type="object" class="btn-secondary"/>
        </footer>
      </form>
    </field>
</record>

<record id="action_product_report_wizard" model="ir.actions.act_window">
  <field name="name">Reporte de Productos</field>
  <field name="res_model">product.report.wizard</field>
  <field name="view_mode">form</field>
  <field name="target">new</field>
</record>

<menuitem id="menu_product_report_root"
          name="Reporte de Productos"
          parent="account.menu_finance_reports"
          action="action_product_report_wizard"/>
</odoo>
