<odoo>
  <template id="product_report_pdf_template">
    <t t-call="web.basic_layout">
      <div class="page">
        <t t-set="doc" t-value="docs[0]"/>

        <!-- Encabezado principal -->
        <div style="text-align: center; margin-bottom: 20px;">
          <h2 style="color: #2c3e50; margin-bottom: 5px;">Reporte de Productos Vendidos</h2>
          <p style="color: #7f8c8d; font-size: 14px;">Análisis de ventas y costos por producto</p>
        </div>

        <!-- Información de filtros -->
        <div style="background-color: #f8f9fa; padding: 15px; border-radius: 5px; margin-bottom: 20px;">
          <div style="display: flex; justify-content: space-between;">
            <div>
              <strong style="color: #2c3e50;">Período:</strong>
              <span t-esc="doc.date_start" style="margin-right: 10px;"/>
              <strong>hasta:</strong>
              <span t-esc="doc.date_end"/>
            </div>
            <div>
              <strong style="color: #2c3e50;">Generado:</strong>
              <span t-esc="datetime.datetime.now().strftime('%d/%m/%Y %H:%M')"/>
            </div>
          </div>
          <div style="margin-top: 10px;">
            <strong style="color: #2c3e50;">Comercial:</strong>
            <span t-esc="doc.user_id and doc.user_id.name or 'Todos'"/>
          </div>
          <t t-if="doc.partner_id">
            <div style="margin-top: 5px;">
              <strong style="color: #2c3e50;">Cliente:</strong>
              <span t-esc="doc.partner_id.name"/>
            </div>
          </t>
        </div>

        <!-- Datos desde Python -->
        <t t-set="rows" t-value="doc._get_grouped_rows()"/>
        <t t-set="group_by_commercial" t-value="not doc.user_id"/>

        <!-- Tabla -->
        <table class="table table-sm" style="width: 100%; border-collapse: collapse; margin-top: 20px;">
          <thead>
            <tr style="background-color: #2c3e50; color: white;">
              <t t-if="group_by_commercial">
                <th style="padding: 12px; text-align: left; border-bottom: 2px solid #34495e;">Comercial</th>
              </t>
              <th style="padding: 12px; text-align: left; border-bottom: 2px solid #34495e;">Producto</th>
              <th style="padding: 12px; text-align: right; border-bottom: 2px solid #34495e;">Precio Unitario (USD)</th>
              <th style="padding: 12px; text-align: right; border-bottom: 2px solid #34495e;">Costo (USD)</th>
              <th style="padding: 12px; text-align: right; border-bottom: 2px solid #34495e;">Entregado</th>
              <!-- NUEVA COLUMNA UDM -->
              <th style="padding: 12px; text-align: center; border-bottom: 2px solid #34495e;">Udm</th>
              <th style="padding: 12px; text-align: right; border-bottom: 2px solid #34495e;">Total de Ventas (USD)</th>
              <th style="padding: 12px; text-align: right; border-bottom: 2px solid #34495e;">Ganancia (USD)</th>
            </tr>
          </thead>
          <tbody>
            <!-- Acumuladores -->
            <t t-set="total_price_unit" t-value="0.0"/>
            <t t-set="total_cost" t-value="0.0"/>
            <t t-set="total_invoiced" t-value="0.0"/>
            <t t-set="total_sales_sum" t-value="0.0"/>
            <t t-set="total_profit_sum" t-value="0.0"/>

            <t t-foreach="rows" t-as="r">
              <t t-set="price_unit" t-value="r.get('price_sum', 0.0)"/>
              <t t-set="cost_total" t-value="r.get('cost_sum', 0.0)"/>
              <t t-set="qty" t-value="r.get('invoiced_sum', 0.0)"/>
              <t t-set="uom_name" t-value="r.get('uom_name', '')"/>
              <t t-set="sales_total" t-value="price_unit * qty"/>
              <t t-set="profit" t-value="sales_total - cost_total"/>

              <tr style="border-bottom: 1px solid #ecf0f1;">
                <t t-if="group_by_commercial">
                  <td style="padding: 10px;">
                    <t t-esc="r.get('commercial_name') or 'Sin asignar'"/>
                  </td>
                </t>
                <td style="padding: 10px;"><t t-esc="r.get('product_name')"/></td>
                <td style="padding: 10px; text-align: right;">$<t t-esc="'{:,.2f}'.format(price_unit)"/></td>
                <td style="padding: 10px; text-align: right;">$<t t-esc="'{:,.2f}'.format(cost_total)"/></td>
                <td style="padding: 10px; text-align: right;"><t t-esc="'{:,.2f}'.format(qty)"/></td>
                <!-- Nueva celda UDM -->
                <td style="padding: 10px; text-align: center;"><t t-esc="uom_name"/></td>
                <td style="padding: 10px; text-align: right;">$<t t-esc="'{:,.2f}'.format(sales_total)"/></td>
                <td style="padding: 10px; text-align: right;">$<t t-esc="'{:,.2f}'.format(profit)"/></td>
              </tr>

              <!-- Totales -->
              <t t-set="total_price_unit" t-value="total_price_unit + price_unit"/>
              <t t-set="total_cost" t-value="total_cost + cost_total"/>
              <t t-set="total_invoiced" t-value="total_invoiced + qty"/>
              <t t-set="total_sales_sum" t-value="total_sales_sum + sales_total"/>
              <t t-set="total_profit_sum" t-value="total_profit_sum + profit"/>
            </t>

            <!-- Fila de TOTALES -->
            <tr style="background-color: #ecf0f1; font-weight: bold;">
              <t t-if="group_by_commercial">
                <td style="padding: 10px;">TOTAL</td>
                <td style="padding: 10px;"></td> <!-- Alinea con Producto -->
              </t>
              <t t-else="">
                <td style="padding: 10px;">TOTAL</td>
              </t>
              <td style="padding: 10px; text-align: right;">$<t t-esc="'{:,.2f}'.format(total_price_unit)"/></td>
              <td style="padding: 10px; text-align: right;">$<t t-esc="'{:,.2f}'.format(total_cost)"/></td>
              <td style="padding: 10px; text-align: right;"><t t-esc="'{:,.2f}'.format(total_invoiced)"/></td>
              <!-- Columna UDM no suma -->
              <td style="padding: 10px;"></td>
              <td style="padding: 10px; text-align: right;">$<t t-esc="'{:,.2f}'.format(total_sales_sum)"/></td>
              <td style="padding: 10px; text-align: right;">$<t t-esc="'{:,.2f}'.format(total_profit_sum)"/></td>
            </tr>
          </tbody>
        </table>

        <!-- Resumen -->
        <t t-if="rows and len(rows) &gt; 0">
          <div style="margin-top: 20px; text-align: right; color: #7f8c8d; font-size: 12px;">
            <strong>Total de productos:</strong> <t t-esc="len(rows)"/>
          </div>
        </t>
      </div>
    </t>
  </template>

  <report
    id="action_product_report_pdf"
    model="product.report.wizard"
    string="Exportar PDF"
    report_type="qweb-pdf"
    name="report_product_prices.product_report_pdf_template"
    file="report_product_prices.product_report_pdf_template"
    print_report_name="'Reporte de Productos'"
  />
</odoo>
