<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_bank_holidays_tree" model="ir.ui.view">
        <field name="name">view.bank.holidays.tree</field>
        <field name="model">bank.holidays.bcv</field>
        <field name="arch" type="xml">
            <tree string="Bank Holidays">
                <field name="date" string="Fecha"/>
                <field name="name" string="Descripcíon"/>
            </tree>
        </field>
    </record>

    <record id="view_bank_holidays_form" model="ir.ui.view">
        <field name="name">view.bank.holidays.form</field>
        <field name="model">bank.holidays.bcv</field>
        <field name="arch" type="xml">
            <form string="Bank Holidays">
                <sheet>
                    <group>
                        <group>
                            <field name="date" string="Fecha"/>
                            <field name="name" string="Descripcíon"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_currency_bcv_form_holidays" model="ir.actions.act_window">
        <field name="name">Bank Holidays</field>
        <field name="res_model">bank.holidays.bcv</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>
