<odoo>
    <record id="view_sale_order_form_inherit" model="ir.ui.view">
        <field name="name">view.sale.order.form.inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="after">
                <div class="alert alert-info text-center o_form_header" role="status"
                    attrs="{'invisible': [('is_credit_limit_warning', '=', False)]}">
                    <field name="is_credit_limit_warning" attrs="{'invisible': [('credit_warning_usd', '=', False)]}"/>
                    <div>
                        <strong>Este cliente ha superado su monto de advertencia:</strong><br/>
                        Límite de advertencia USD: <field name="credit_warning_usd"/> <br/>
                        Total pedido + deuda: <field name="amount_total_dual"/> + <field name="amount_due_usd"/>
                    </div>
                </div>
                <div class="alert alert-warning text-center o_form_header" role="status"
                     attrs="{'invisible': [('is_credit_limit_approval', '=', False)]}">
                    <div>
                          <strong>El límite de bloqueo de clientes es:
                              <field name="customer_blocking_limit"/> / $
                              <field name="customer_blocking_limit_usd"/>
                          </strong>
                        <br/>
                        <strong>El monto adeudado por el cliente es:
                            <field name="amount_due"/> / $
                            <field name="amount_due_usd"/>
                        </strong>
                    </div>
                </div>
            </xpath>
            <xpath expr="//button[@name='action_confirm'][2]" position="attributes">
                <attribute name="attrs">{'invisible': ['|',('state', 'not in', ['draft']),
                    ('is_credit_limit_approval', '=', True)]}
                </attribute>
            </xpath>
            <xpath expr="//header" position="inside">
                <button name="send_credit_limit_approval" string="Aprobación del límite de crédito" type="object"
                    class="oe_highlight" attrs="{'invisible': ['|', ('is_credit_limit_approval', '=', False), ('state', 'not in', ['draft', 'sent'])]}" groups="sales_team.group_sale_manager"/>
                <button name="approved_credit_limit_from_sales_manager" string="Aprobado" type="object"
                    class="oe_highlight" attrs="{'invisible': [('state', 'not in', ['sales_approval'])]}"
                    groups="sale_account_manager_customer_credit_limit_approval.group_sales_approval"/>
                <button name="approved_credit_limit_from_account_manager" string="Aprobado" type="object"
                    class="oe_highlight" attrs="{'invisible': [('state', 'not in', ['finance_approval'])]}"
                    groups="sale_account_manager_customer_credit_limit_approval.group_finance_approval"/>
                <button name="reject_sale_order" string="Rechazado" type="object"
                    class="oe_highlight"
                    attrs="{'invisible': [('state', 'not in', ['sales_approval'])]}"
                    groups="sale_account_manager_customer_credit_limit_approval.group_sales_approval"/>
                <button name="reject_sale_order" string="Rechazado" type="object"
                    class="oe_highlight"
                    attrs="{'invisible': [('state', 'not in', ['finance_approval'])]}"
                    groups="sale_account_manager_customer_credit_limit_approval.group_finance_approval"/>
            </xpath>
            <xpath expr="//field[@name='payment_term_id']" position="after">
                <field name="company_currency_id" invisible="1"/>
                <field name="is_credit_limit_approval" invisible="1"/>
                <field name="is_credit_limit_final_approved" invisible="1"/>
            </xpath>
            <xpath expr="//button[@name='action_confirm'][1]" position="attributes">
                <attribute name="attrs">{'invisible': [('state', 'not in', ['sent', 'approved'])]}</attribute>
            </xpath>
            <xpath expr="//page/field[@name='order_line']" position="attributes">
                <attribute name="attrs">{'readonly': [('state', 'in', ('done','cancel', 'approved'))]}</attribute>
            </xpath>
        </field>
    </record>
</odoo>