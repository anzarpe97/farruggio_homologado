<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_purchase_order_form_inherit_fully_paid" model="ir.ui.view">
        <field name="name">purchase.order.form.inherit.fully.paid</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
        <button name="action_mark_fully_invoiced"
            type="object"
            string="Cerrar Orden"
            class="btn-primary"
            attrs="{ 'invisible': ['|', ('state', 'in', ('cancel',)), ('invoice_status', '=', 'invoiced')] }"/>
            </xpath>
            <!-- Avoid using page[@string] as selector (not allowed). Insert a new page into the notebook instead -->
            <xpath expr="//sheet/notebook" position="inside">
                <page string="Facturación (ext)">
                    <group>
                        <field name="invoice_status"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
