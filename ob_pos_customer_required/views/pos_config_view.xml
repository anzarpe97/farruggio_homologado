<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record model="ir.ui.view" id="view_pos_customer_validation">
            <field name="name">pos.config.form.inherit.view.customer.validation</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//div[@id='pos_interface_section']" position="after">
                    <h2 name="customer_validation">PoS Customer Required</h2>
                    <div class="row mt16 o_settings_container">
                        <div id="pos_customer_required" class="col-xs-12 col-md-6 o_setting_box">
                            <div class="o_setting_left_pane">
                                <field name="customer_required"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="customer_required" string="Customer Required?"/>
                                <div class="text-muted">
                                    Customer Required in Point of Sale
                                </div>
                            </div>
                        </div>
                    </div>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
