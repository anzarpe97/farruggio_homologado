<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template t-name="custom_stock_picking_report.report_stock_picking_custom">
        <t t-set="_styles">
            <style type="text/css">
                @page { margin: 0 !important; size: auto; }
                html, body { margin: 0 !important; padding: 0 !important; }
                body { margin-top: 0 !important; padding-top: 0 !important; }
                main, .page { margin: 0 !important; padding: 0 !important; }
                @media print {
                    html, body, main, .page {
                        margin: 0 !important;
                        padding: 0 !important;
                    }
                }
            </style>
        </t>
        <t t-foreach="docs" t-as="o">
            <main>
                <div style="width:100%; display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:10px; margin-top:0 !important; padding-top:0 !important;">
                    <div style="max-width:220px; margin-top:0; padding-top:0;">
                        <img t-if="o.company_id.logo" t-att-src="image_data_uri(o.company_id.logo)" style="max-height:60px; max-width:200px;" alt="Logo"/>
                    </div>
                    <div style="font-size:11px; text-align:right; margin-top:0;">
                        <strong t-esc="o.company_id.name"/><br/>
                        <span t-esc="o.company_id.partner_id.street"/>
                        <t t-if="o.company_id.partner_id.street">, </t>
                        <span t-esc="o.company_id.partner_id.city"/>
                        <t t-if="o.company_id.partner_id.state_id">, </t>
                        <span t-esc="o.company_id.partner_id.state_id.name"/>
                        <t t-if="o.company_id.partner_id.country_id">, </t>
                        <span t-esc="o.company_id.partner_id.country_id.name"/>
                        <br/>
                        <t t-if="o.company_id.vat">NIF: <span t-esc="o.company_id.vat"/></t>
                    </div>
                </div>
            
                <div class="page" style="font-size:10px; padding: 0px 20px 10px 20px;">
                    <div style="display:flex; justify-content:space-between;">
                        <div style="min-width: 220px; margin-bottom:8px;">
                            <strong>Direccion del cliente:</strong><br/>
                            <span t-esc="o.partner_id.display_name"/><br/>
                            <span t-esc="o.partner_id.street"/>
                            <t t-if="o.partner_id.street">, </t>
                            <span t-esc="o.partner_id.city"/>
                            <t t-if="o.partner_id.state_id">, </t>
                            <span t-esc="o.partner_id.state_id.name"/>
                            <t t-if="o.partner_id.country_id">, </t>
                            <span t-esc="o.partner_id.country_id.name"/>
                            <br/>
                            <t t-if="o.partner_id.vat">NIF: <span t-esc="o.partner_id.vat"/></t>
                        </div>
                        <div style="min-width: 220px;">
                            <strong>Direccion de entrega:</strong><br/>
                            <span t-esc="o.partner_id.display_name"/><br/>
                            <span t-esc="o.partner_id.street"/><br/>
                            <span t-esc="o.partner_id.city"/>
                        </div>
                    </div>
                    <div style="margin: 10px 0 5px 0;">
                        <strong>ORDEN DE ENTREGA:</strong> <span t-esc="o.name"/>
                    </div>
                    <div style="margin-bottom: 10px;">
                        <span>Orden: </span><span t-esc="o.origin"/>
                        <span style="margin-left:30px;">Fecha de envio: </span><span t-esc="o.scheduled_date and o.scheduled_date.strftime('%d/%m/%Y %H:%M:%S') or ''"/>
                    </div>
                    <div style="margin-bottom: 10px;">
                        <span><strong>Comercial cliente:</strong> <t t-esc="o.partner_id.user_id.name if o.partner_id and o.partner_id.user_id else ''"/></span>
                        <span style="margin-left:30px;"><strong>Ruta:</strong> <t t-esc="o.partner_id.team_id.name if o.partner_id and o.partner_id.team_id else ''"/></span>
                    </div>
                    <table class="table table-sm" style="width:100%; font-size:9.5px; border-collapse: collapse;">
                        <thead>
                            <tr style="background:#f5f5f5;">
                                <th style="border:1px solid #888; padding:2px 4px;">Producto</th>
                                <th style="border:1px solid #888; padding:2px 4px;">Descripcion</th>
                                <th style="border:1px solid #888; padding:2px 4px;">Pedido</th>
                                <th style="border:1px solid #888; padding:2px 4px;">Entregado</th>
                                <th style="border:1px solid #888; padding:2px 4px;">Und</th>
                                <th style="border:1px solid #888; padding:2px 4px;">Nro de Paquetes</th>
                                <th style="border:1px solid #888; padding:2px 4px;">Nro de Cestas</th>
                                <th style="border:1px solid #888; padding:2px 4px;">Notas</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="o.move_ids_without_package" t-as="move">
                                <td style="border:1px solid #888; padding:2px 4px;" t-esc="move.product_id.display_name"/>
                                <td style="border:1px solid #888; padding:2px 4px;" t-esc="o.get_sale_line_description(move)"/>
                                <td style="border:1px solid #888; padding:2px 4px;">
                                    <span t-esc="move.product_uom_qty"/>
                                    <span t-esc="move.product_uom.name"/>
                                </td>
                                <td style="border:1px solid #888; padding:2px 4px;">
                                    <span t-esc="move.quantity_done"/>
                                    <span t-esc="move.product_uom.name"/>
                                </td>
                                <td style="border:1px solid #888; padding:2px 4px;" t-esc="move.product_uom.name"/>
                                <td style="border:1px solid #888; padding:2px 4px;" t-esc="o.get_nro_pqts(move)"/>
                                <td style="border:1px solid #888; padding:2px 4px;" t-esc="o.get_nro_cestas(move)"/>
                                <td style="border:1px solid #888; padding:2px 4px;" t-esc="move.notas"/>
                            </tr>
                        </tbody>
                    </table>
                    <div style="margin-top:40px;">
                        <table style="width:100%; text-align:center; border:none; margin-top:20px;">
                            <tr>
                                <td style="width:33%; vertical-align:bottom; padding:0 10px;">
                                    <div style="height:60px; border-bottom:1px solid #000; margin-bottom:5px;"></div>
                                    <span>Elaborado por</span>
                                </td>
                                <td style="width:33%; vertical-align:bottom; padding:0 10px;">
                                    <div style="height:60px; border-bottom:1px solid #000; margin-bottom:5px;"></div>
                                    <span>Despachado por</span>
                                </td>
                                <td style="width:33%; vertical-align:bottom; padding:0 10px;">
                                    <div style="height:60px; border-bottom:1px solid #000; margin-bottom:5px;"></div>
                                    <span>Recibido por</span>
                                </td>
                            </tr>
                        </table>
                        <div style="text-align:center; font-size:11px; margin-top:15px; font-weight:bold;">Documento no fiscal</div>
                    </div>
                </div>
            </main>
        </t>
    </template>
</odoo>
