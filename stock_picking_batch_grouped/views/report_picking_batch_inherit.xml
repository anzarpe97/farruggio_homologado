<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <template id="report_picking_batch_grouped" inherit_id="stock_picking_batch.report_picking_batch">
    <xpath expr="//div[@class='page']" position="replace">
      <div class="page">
        <t t-foreach="docs" t-as="doc">
        <div class="d-flex">
          <div><h3>Summary: <span t-field="doc.name"/></h3></div>
          <div class="me-auto">
            <div t-field="doc.name" t-options="{'widget': 'barcode', 'width': 600, 'height': 150, 'img_style': 'width:300px;height:50px;'}"/>
          </div>
        </div>
        <div t-if="doc.user_id">
          <strong>Responsible:</strong>
          <span t-field="doc.user_id"/>
        </div><br/>
        <!-- <table class="table table-condensed">
          <thead>
            <tr>
              <th>Transfer</th>
              <th>Barcode</th>
              <th>Status</th>
              <th>Scheduled Date</th>
            </tr>
          </thead>
          <tbody>
            <tr t-foreach="doc.picking_ids" t-as="pick">
              <td><span t-field="pick.name"/></td>
              <td>
                <div t-field="pick.name" t-options="{'widget': 'barcode', 'quiet': 0, 'width': 400, 'height': 100, 'img_style': 'width:200px;height:50px;'}"/>
              </td>
              <td><span t-field="pick.state"/></td>
              <td><span t-field="pick.scheduled_date"/></td>
            </tr>
          </tbody>
        </table>

        <p style="page-break-after: always;"/> -->

        <h3><span t-field="doc.name"/></h3>
        <div t-if="doc.user_id">
          <strong>Responsible:</strong>
          <span t-field="doc.user_id"/>
        </div><br/>
        
        <!-- Tabla de productos con columna Transfer removida -->
        <table class="table table-condensed">
          <thead>
            <tr>
              <th>Producto</th>
              <th>Cantidad</th>
              <!-- Transfer removida -->
              <th t-if="has_serial_number" width="15%">
                <strong>Lot/Serial Number</strong>
              </th>
              <th t-if="has_barcode" width="15%" class="text-center">
                <strong>Product Barcode</strong>
              </th>
              <th t-if="has_package" width="15%">
                <strong>Package</strong>
              </th>
            </tr>
          </thead>
          <tbody>
            <t t-foreach="doc.get_grouped_move_lines()" t-as="grouped_move">
              <tr>
                <td><span t-esc="grouped_move['product'].display_name"/></td>
                <td>
                  <t t-if="has_package or docs.picking_ids[0].state == 'done'">
                    <span t-esc="grouped_move['qty_done']"/>
                  </t>
                  <t t-else="">
                    <span t-esc="grouped_move['reserved_uom_qty']"/>
                  </t>
                  <span t-esc="grouped_move['uom'].display_name"/>
                </td>
                <!-- Transfer removida -->
                <td t-if="has_serial_number" class="text-center h6" width="15%">
                  <t t-foreach="grouped_move['lot_ids']" t-as="lot">
                    <div t-field="lot.name" t-options="{'widget': 'barcode', 'humanreadable': 1, 'width': 600, 'height': 100, 'img_style': 'width:100%;height:35px;'}"/>
                  </t>
                </td>
                <td width="15%" class="text-center" t-if="has_barcode">
                  <t t-if="grouped_move['barcode']">
                    <div t-esc="grouped_move['barcode']" t-options="{'widget': 'barcode', 'symbology': 'auto', 'width': 600, 'height': 100, 'img_style': 'width:100%;height:35px;'}"/>
                  </t>
                </td>
                <td t-if="has_package" width="15%">
                  <t t-foreach="grouped_move['packages']" t-as="package">
                    <span t-esc="package.name"/>
                    <t t-if="not loop.last">, </t>
                  </t>
                </td>
              </tr>
            </t>
          </tbody>
        </table>
      </t>
      </div>
    </xpath>
  </template>
</odoo>
