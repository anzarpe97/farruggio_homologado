<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="report_invoice_template_dual">
        <t t-name="forma_libre.report_invoice_template_dual">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="doc">
                <html lang="es">
                <head>
                    <meta charset="UTF-8" />
                    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
                </head>
                <body>
                    <main style="font-family: 'Open Sans', sans-serif;">

                        <!-- Encabezado empresa -->
                        <table style="width: 100%; font-size: 5px; position: relative; top: 24px; margin-bottom: 16px;">
                            <tr>
                                <td style="width: 50%; vertical-align: top; padding-right: 10px; font-size: 8px; margin-top: 2px;">
                                    <p style="margin: 0; font-size: 8px;"><strong>Cliente:</strong> <t t-esc="doc.partner_id.name or ''"/></p>
                                    <p style="margin: 0; font-size: 8px;"><strong>R.I.F:</strong> <t t-esc="doc.partner_id.vat or doc.partner_id.identification_id or ''"/></p>
                                    <p style="margin: 0; font-size: 8px;"><strong>Dirección Fiscal:</strong></p>
                                    <div style="margin-left: 5px; margin-bottom: 1px; font-size: 8px;">
                                        <t t-esc="doc.partner_id.contact_address or ''"/>
                                    </div>
                                    <t t-set="shipping_address" t-value="doc.partner_shipping_id or (doc.invoice_origin and env['sale.order'].search([('name','=',doc.invoice_origin)], limit=1).partner_shipping_id)"/>
                                    <t t-if="shipping_address and shipping_address.id != doc.partner_id.id">
                                        <p style="margin: 0;"><strong>Dirección de Entrega:</strong></p>
                                        <div style="margin-left: 5px;">
                                            <t t-esc="shipping_address.contact_address or ''"/>
                                            <t t-if="shipping_address.sica">
                                                <br/><strong>SICA:</strong> <t t-esc="shipping_address.sica or ''"/>
                                            </t>
                                        </div>
                                    </t>
                                    <p style="margin: 0;"><strong>Telefono:</strong> <t t-esc="doc.partner_id.phone or ''"/></p>
                                </td>
                                <!-- Columna de Factura -->
                                <td style="width: 50%; text-align: right; vertical-align: top; font-size: 8px; top:15px;">
                                    <p style="margin: 0;">
                                        <strong>
                                            <t t-if="doc.move_type == 'out_invoice'">
                                            <t t-if="doc.debit_origin_id">Nota de Débito:</t>
                                            <t t-else=""><span>Número de Factura:</span></t>
                                            </t>
                                            <t t-elif="doc.move_type == 'out_refund'">Nota de Crédito:</t>
                                        </strong>
                                        <t t-esc="doc.name or ''"/>
                                    </p>
                                    <t t-if="doc.move_type == 'out_refund'">
                                        <t t-if="doc.reversed_entry_id">
                                            <p style="margin: 0;"><strong>Documento Afectado:</strong> <t t-esc="doc.reversed_entry_id.name"/></p>
                                            <p style="margin: 0;"><strong>Fecha de Documento Afectado:</strong> <t t-esc="doc.reversed_entry_id.date.strftime('%d/%m/%Y')"/></p>
                                        </t>
                                        <t t-else="">
                                            <t t-set="factura_relacionada" t-value="None"/>
                                            <t t-foreach="doc.line_ids" t-as="line">
                                                <!-- Buscamos reconciliaciones con facturas -->
                                                <t t-if="not factura_relacionada and line.matched_debit_ids">
                                                    <t t-set="matched_line" t-value="line.matched_debit_ids[0].debit_move_id.move_id"/>
                                                    <t t-if="matched_line.move_type == 'out_invoice'">
                                                        <t t-set="factura_relacionada" t-value="matched_line"/>
                                                    </t>
                                                </t>
                                                <t t-if="not factura_relacionada and line.matched_credit_ids">
                                                    <t t-set="matched_line" t-value="line.matched_credit_ids[0].credit_move_id.move_id"/>
                                                    <t t-if="matched_line.move_type == 'out_invoice'">
                                                        <t t-set="factura_relacionada" t-value="matched_line"/>
                                                    </t>
                                                </t>
                                            </t>
                                            <t t-if="factura_relacionada">
                                                <p style="margin: 0;"><strong>Documento Afectado:</strong> <t t-esc="factura_relacionada.name"/></p>
                                                <p style="margin: 0;"><strong>Fecha de Documento Afectado:</strong> <t t-esc="factura_relacionada.date.strftime('%d/%m/%Y')"/></p>
                                            </t>
                                        </t>
                                    </t>
                                    <t t-if="doc.move_type == 'out_invoice' and doc.debit_origin_id">
                                        <p style="margin: 0;"><strong>Documento Afectado:</strong> <t t-esc="doc.debit_origin_id.name"/></p>
                                    </t>
                                    <t t-if="doc.move_type == 'out_invoice' and doc.debit_origin_id">
                                        <p style="margin: 0;"><strong>Fecha de Documento Afectado:</strong> <t t-esc="doc.debit_origin_id.date.strftime('%d/%m/%Y')"/></p>
                                    </t>
                                    <p style="margin: 0;"><strong>Fecha:</strong> <t t-esc="doc.invoice_date.strftime('%d/%m/%Y') if doc.invoice_date else ''"/></p>
                                    <p style="margin: 0;"><strong>Término de Pago:</strong> <t t-esc="doc.invoice_payment_term_id.name or ''"/></p>
                                    <p style="margin: 0;"><strong>Vendedor:</strong> <t t-esc="doc.invoice_user_id.name or ''"/></p>
                                        <t t-if="doc.obra_no">
                                            <p style="margin: 0;"><strong>Obra No:</strong> <t t-esc="doc.obra_no or ''"/></p>
                                        </t>
                                        <t t-if="doc.contrato_no">
                                            <p style="margin: 0;"><strong>No. de Contrato:</strong> <t t-esc="doc.contrato_no or ''"/></p>
                                        </t>
                                        <t t-if="doc.proveedor_no">
                                            <p style="margin: 0;"><strong>No. de Proveedor:</strong> <t t-esc="doc.proveedor_no or ''"/></p>
                                        </t>
                                        <t t-if="doc.hoja_entrada_servicio">
                                            <p style="margin: 0;"><strong>No. Hoja de Entrada de Servicio:</strong> <t t-esc="doc.hoja_entrada_servicio or ''"/></p>
                                        </t>
                                </td>
                            </tr>
                        </table>

                        <!-- Tabla de Productos -->
                        <table class="table table-sm" style="width: 100%; border-collapse: collapse; font-size: 8px; margin-top: 20px; margin-bottom: 7px;">
                            <thead>
                                <tr style="border-bottom: 1px solid #ccc;">
                                    <th style="text-align: left; padding: 2px 5px;">Codigo</th>
                                    <th style="text-align: left; padding: 2px 5px;">Producto</th>
                                    <th style="text-align: right; padding: 2px 5px;">Cantidad</th>
                                    <th style="text-align: right; padding: 2px 5px;">Precio</th>
                                    <th style="text-align: center; padding: 2px 5px;">Dscto %</th>
                                    <th style="text-align: right; padding: 2px 5px;">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="doc.invoice_line_ids[:20]" t-as="line">
                                    <td style="border: none; text-align: left; font-size: 8px; padding: 2px 5px;">
                                        <t t-esc="line.product_id.default_code or ''"/>
                                    </td>
                                    <td style="border: none; text-align: left; font-size: 8px; padding: 2px 5px;">
                                        <t t-esc="line.product_id.name or ''"/>
                                        <t t-if="not line.tax_ids or all(t.amount == 0 for t in line.tax_ids)">
                                            (E)
                                        </t>
                                        <t t-else="">
                                            (G)
                                        </t>
                                    </td>
                                    <td style="border: none; text-align: right; font-size: 8px; padding: 2px 5px;">
                                        <t t-esc="'%0.2f' % (line.quantity or 0.00)"/>
                                    </td>
                                    <td style="border: none; text-align: right; font-size: 8px; padding: 2px 5px;">
                                        <t t-esc="'{:,.2f}'.format(line.price_unit).replace(',', 'X').replace('.', ',').replace('X', '.')"/>
                                    </td>
                                    <td style="border: none; text-align: center; font-size: 8px; padding: 2px 5px;">
                                        <t t-esc="line.discount"/>
                                    </td>
                                    <td style="border: none; text-align: right; font-size: 8px; padding: 2px 5px;">
                                        <t t-esc="'{:,.2f}'.format(line.price_subtotal).replace(',', 'X').replace('.', ',').replace('X', '.')"/>
                                    </td>
                                </tr>
                            </tbody>  
                        </table>

                        <div style="position: fixed; top: 590px; left: 10px; width: 90%; text-align: center; font-size: 8px; padding: 3px;">
                            <t t-set="tasa" t-value="doc.tax_today or 1.0"/>
                            <t t-if="doc.currency_id.name == 'USD'">
                                <!-- Cuando la moneda es USD, Bs = USD * tasa, USD queda igual -->
                                <t t-set="total_imponible" t-value="(doc.total_imponible or 0.0) * tasa"/>
                                <t t-set="tax_exento" t-value="(doc.tax_exento or 0.0) * tasa"/>
                                <t t-set="tax_8" t-value="(doc.tax_8 or 0.0) * tasa"/>
                                <t t-set="tax_16" t-value="(doc.tax_16 or 0.0) * tasa"/>
                                <t t-set="tax_31" t-value="(doc.tax_31 or 0.0) * tasa"/>
                                <t t-set="base_8" t-value="(doc.base_8 or 0.0) * tasa"/>
                                <t t-set="base_16" t-value="(doc.base_16 or 0.0) * tasa"/>
                                <t t-set="base_31" t-value="(doc.base_31 or 0.0) * tasa"/>
                                <t t-set="amount_total" t-value="(doc.amount_total or 0.0) * tasa"/>
                                <!-- Variables USD quedan igual -->
                                <t t-set="total_imponible_usd" t-value="(doc.total_imponible or 0.0)"/>
                                <t t-set="tax_exento_usd" t-value="(doc.tax_exento or 0.0)"/>
                                <t t-set="tax_8_usd" t-value="(doc.tax_8 or 0.0)"/>
                                <t t-set="tax_16_usd" t-value="(doc.tax_16 or 0.0)"/>
                                <t t-set="tax_31_usd" t-value="(doc.tax_31 or 0.0)"/>
                                <t t-set="base_8_usd" t-value="(doc.base_8 or 0.0)"/>
                                <t t-set="base_16_usd" t-value="(doc.base_16 or 0.0)"/>
                                <t t-set="base_31_usd" t-value="(doc.base_31 or 0.0) "/>
                                <t t-set="amount_total_usd" t-value="(doc.amount_total or 0.0)"/>
                            </t>
                            <t t-elif="doc.currency_id.name == 'VEF' or doc.currency_id.name == 'VES'">
                                <!-- Cuando la moneda es VEF/VES, USD = Bs / tasa, Bs queda igual -->
                                <t t-set="total_imponible_usd" t-value="(doc.total_imponible or 0.0) / tasa"/>
                                <t t-set="tax_exento_usd" t-value="(doc.tax_exento or 0.0) / tasa"/>
                                <t t-set="tax_8_usd" t-value="(doc.tax_8 or 0.0) / tasa"/>
                                <t t-set="tax_16_usd" t-value="(doc.tax_16 or 0.0) / tasa"/>
                                <t t-set="tax_31_usd" t-value="(doc.tax_31 or 0.0) / tasa"/>
                                <t t-set="base_8_usd" t-value="(doc.base_8 or 0.0) / tasa"/>
                                <t t-set="base_16_usd" t-value="(doc.base_16 or 0.0) / tasa"/>
                                <t t-set="base_31_usd" t-value="(doc.base_31 or 0.0) / tasa"/>
                                <t t-set="amount_total_usd" t-value="(doc.amount_total or 0.0) / tasa"/>
                                <!-- Variables Bs quedan igual -->
                                <t t-set="total_imponible" t-value="doc.total_imponible or 0.0"/>
                                <t t-set="tax_exento" t-value="doc.tax_exento or 0.0"/>
                                <t t-set="tax_8" t-value="doc.tax_8 or 0.0"/>
                                <t t-set="tax_16" t-value="doc.tax_16 or 0.0"/>
                                <t t-set="tax_31" t-value="doc.tax_31 or 0.0"/>
                                <t t-set="base_8" t-value="doc.base_8 or 0.0"/>
                                <t t-set="base_16" t-value="doc.base_16 or 0.0"/>
                                <t t-set="base_31" t-value="doc.base_31 or 0.0"/>
                                <t t-set="amount_total" t-value="doc.amount_total or 0.0"/>
                            </t>
                            <t t-else="">
                                <!-- Para otras monedas, usamos los valores Bs y USD directamente -->
                                <t t-set="total_imponible" t-value="doc.total_imponible or 0.0"/>
                                <t t-set="tax_exento" t-value="doc.tax_exento or 0.0"/>
                                <t t-set="tax_8" t-value="doc.tax_8 or 0.0"/>
                                <t t-set="tax_16" t-value="doc.tax_16 or 0.0"/>
                                <t t-set="tax_31" t-value="doc.tax_31 or 0.0"/>
                                <t t-set="base_8" t-value="doc.base_8 or 0.0"/>
                                <t t-set="base_16" t-value="doc.base_16 or 0.0"/>
                                <t t-set="base_31" t-value="doc.base_31 or 0.0"/>
                                <t t-set="amount_total" t-value="doc.amount_total or 0.0"/>
                                <t t-set="total_imponible_usd" t-value="doc.total_imponible_usd or 0.0"/>
                                <t t-set="tax_exento_usd" t-value="doc.tax_exento_usd or 0.0"/>
                                <t t-set="tax_8_usd" t-value="doc.tax_8_usd or 0.0"/>
                                <t t-set="tax_16_usd" t-value="doc.tax_16_usd or 0.0"/>
                                <t t-set="tax_31_usd" t-value="doc.tax_31_usd or 0.0"/>
                                <t t-set="base_8_usd" t-value="doc.base_8_usd or 0.0"/>
                                <t t-set="base_16_usd" t-value="doc.base_16_usd or 0.0"/>
                                <t t-set="base_31_usd" t-value="doc.base_31_usd or 0.0"/>
                                <t t-set="amount_total_usd" t-value="doc.amount_total_usd or 0.0"/>
                            </t>
                            <table style="width: 100%; border-collapse: collapse; font-size: 8px;">
                                <thead>
                                    <tr>
                                        <th colspan="2" style="border-right: 1px solid black;">Monto en Bolívares (Bs.)</th>
                                        <th colspan="2">Monto en Dólares (US$.)</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <!-- Sub-Total -->
                                    <tr>
                                        <td><strong>Sub-Total:</strong></td>
                                        <td style="border-right: 1px solid black; text-align: right; padding-right: 3px;">
                                            <t t-esc="'{:,.2f}'.format((total_imponible or 0.0) + (tax_exento or 0.0)).replace(',', 'X').replace('.', ',').replace('X', '.')"/>
                                        </td>
                                        <td><strong>Sub-Total Ref:</strong></td>
                                        <td style="text-align: right;">
                                            <t t-esc="'{:,.2f}'.format((total_imponible_usd or 0.0) + (tax_exento_usd or 0.0)).replace(',', 'X').replace('.', ',').replace('X', '.')"/>
                                        </td>
                                    </tr>
                                    <!-- Total Exento -->
                                    <t t-if="(tax_exento or 0.0) != 0.0 or (tax_exento_usd or 0.0) != 0.0">
                                    <tr>
                                            <td><strong>Total Exento:</strong></td>
                                            <td style="border-right: 1px solid black; text-align: right; padding-right: 3px;">
                                                <t t-esc="'{:,.2f}'.format(tax_exento or 0.0).replace(',', 'X').replace('.', ',').replace('X', '.')"/>
                                            </td>
                                            <td><strong>Total Exento Ref:</strong></td>
                                            <td style="text-align: right;">
                                                <t t-esc="'{:,.2f}'.format(tax_exento_usd or 0.0).replace(',', 'X').replace('.', ',').replace('X', '.')"/>
                                            </td>
                                        </tr>
                                    </t>
                                    <!-- Base Imponible -->
                                    <tr>
                                        <td><strong>Base Imponible:</strong></td>
                                        <td style="border-right: 1px solid black; text-align: right; padding-right: 3px;">
                                            <t t-esc="'{:,.2f}'.format(total_imponible or 0.0).replace(',', 'X').replace('.', ',').replace('X', '.')"/>
                                        </td>
                                        <td><strong>Base Imponible Ref:</strong></td>
                                        <td style="text-align: right;">
                                            <t t-esc="'{:,.2f}'.format(total_imponible_usd or 0.0).replace(',', 'X').replace('.', ',').replace('X', '.')"/>
                                        </td>
                                    </tr>
                                    <!-- IVA 8% -->
                                    <t t-if="tax_8 != 0 or tax_8_usd != 0">
                                        <tr>
                                            <td>
                                                <strong>IVA 8% Sobre 
                                                    <t t-esc="'{:,.2f}'.format(base_8 or 0.0).replace(',', 'X').replace('.', ',').replace('X', '.')"/> :
                                                </strong>
                                            </td>
                                            <td style="border-right: 1px solid black; text-align: right; padding-right: 3px;">
                                                <t t-esc="'{:,.2f}'.format(tax_8 or 0.0).replace(',', 'X').replace('.', ',').replace('X', '.')"/>
                                            </td>
                                            <td>
                                                <strong>IVA 8% Ref Sobre 
                                                    <t t-esc="'{:,.2f}'.format(base_8_usd or 0.0).replace(',', 'X').replace('.', ',').replace('X', '.')"/>: 
                                                </strong>
                                            </td>
                                            <td style="text-align: right;">
                                                <t t-esc="'{:,.2f}'.format(tax_8_usd or 0.0).replace(',', 'X').replace('.', ',').replace('X', '.')"/>
                                            </td>
                                        </tr>
                                    </t>
                                    <!-- IVA 16% -->
                                    <t t-if="tax_16 != 0 or tax_16_usd != 0">
                                        <tr>
                                            <td>
                                                <strong>IVA 16% Sobre 
                                                    <t t-esc="'{:,.2f}'.format(base_16 or 0.0).replace(',', 'X').replace('.', ',').replace('X', '.')"/> :
                                                </strong>
                                            </td>
                                            <td style="border-right: 1px solid black; text-align: right; padding-right: 3px;">
                                                <t t-esc="'{:,.2f}'.format(tax_16 or 0.0).replace(',', 'X').replace('.', ',').replace('X', '.')"/>
                                            </td>
                                            <td>
                                                <strong>IVA 16% Ref Sobre 
                                                    <t t-esc="'{:,.2f}'.format(base_16_usd or 0.0).replace(',', 'X').replace('.', ',').replace('X', '.')"/>: 
                                                </strong>
                                            </td>
                                            <td style="text-align: right;">
                                                <t t-esc="'{:,.2f}'.format(tax_16_usd or 0.0).replace(',', 'X').replace('.', ',').replace('X', '.')"/>
                                            </td>
                                        </tr>
                                    </t>
                                    <!-- IVA 31% -->
                                    <t t-if="tax_31 != 0 or tax_31_usd != 0">
                                        <tr>
                                            <td>
                                                <strong>IVA 31% Sobre 
                                                    <t t-esc="'{:,.2f}'.format(base_31 or 0.0).replace(',', 'X').replace('.', ',').replace('X', '.')"/> :
                                                </strong>
                                            </td>
                                            <td style="border-right: 1px solid black; text-align: right; padding-right: 10px;">
                                                <t t-esc="'{:,.2f}'.format(tax_31 or 0.0).replace(',', 'X').replace('.', ',').replace('X', '.')"/>
                                            </td>
                                            <td>
                                                <strong>IVA 31% Ref Sobre 
                                                    <t t-esc="'{:,.2f}'.format(base_31_usd or 0.0).replace(',', 'X').replace('.', ',').replace('X', '.')"/>:
                                                </strong>
                                            </td>
                                            <td style="text-align: right;">
                                                <t t-esc="'{:,.2f}'.format(tax_31_usd or 0.0).replace(',', 'X').replace('.', ',').replace('X', '.')"/>
                                            </td>
                                        </tr>
                                    </t>
                                    <!-- Total General -->
                                    <tr>
                                        <td><strong>Total General Bs.:</strong></td>
                                        <td style="border-right: 1px solid black; text-align: right; padding-right: 10px;">
                                            <t t-esc="'{:,.2f}'.format(amount_total or 0.0).replace(',', 'X').replace('.', ',').replace('X', '.')"/>
                                        </td>
                                        <td><strong>Total General Ref:</strong></td>
                                        <td style="text-align: right;">
                                            <t t-esc="'{:,.2f}'.format(amount_total_usd or 0.0).replace(',', 'X').replace('.', ',').replace('X', '.')"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td colspan="4" style="text-align: left; padding-top: 10px;">
                                            <p style="margin: 0;"><strong>
                                                En caso de pagar la totalidad de la factura o porción con moneda extranjera, se cobrará el 3% de IGTF según Gaceta Oficial 42.339 de fecha 25/02/2022
                                            </strong></p>

                                            <p style="margin: 0; margin-top: 8px;"><strong>
                                                Tasa Vigente al <span t-field="doc.invoice_date" t-options='{"widget": "date", "format": "dd/MM/yyyy"}'/> según el BCV:
                                                <span t-field="doc.tax_today" t-options='{"widget": "float", "precision": 4}'/>
                                            </strong></p>
                                            
                                            <hr style="margin: 10px 0;" />
                                            <p style="margin: 0;">
                                                FACTURA SEGUN CONVENIO CAMBIARIO N°1 GOE N°6.405 DE FECHA 07/09/2018. FACTURA CALCULADA A LA TASA BCV ACTUAL Bs. POR US$
                                                DOLAR <span t-field="doc.tax_today" t-options='{"widget": "float", "precision": 4}'/> PARA EFECTOS DEL IVA DE CONFORMIDAD CON LO ESTABLECIDO EN EL ARTICULO 116 DEL BCV.
                                                PAGARA EN BOLIVARES A LA TASA BCV DEL DIA.
                                            </p>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                        <!-- Indicador Original o Copia -->
                        <div style="width: 100%; text-align: center; margin-top: 20px; font-size: 12px;">
                            <t t-if="doc.print_count > 1">
                                <div style="
                                    top: 50%;
                                    left: 50%;
                                    transform: translate(-50%, -50%) rotate(-30deg);
                                    font-size: 14px;
                                    color: rgba(121, 11, 11, 0.3);
                                    font-weight: 900;
                                    z-index: -1;
                                    white-space: nowrap;
                                    pointer-events: none;
                                    text-align: center;
                                ">
                                    REIMPRESIÓN - SIN DERECHO A CRÉDITO FISCAL
                                </div>
                            </t>
                            <t t-else="">
                                <span style="font-weight: bold;"></span>
                            </t>
                        </div>


                    </main>
                </body>
            </html>
        </t>
    </t>
</t>
</template>

    <record id="view_move_form_inherit_dual_print" model="ir.ui.view">
        <field name="name">account.move.form.dual.print</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <!-- Aseguramos que los campos estén cargados en la vista -->
                <field name="move_type" invisible="1"/>
                <field name="state" invisible="1"/>
            </xpath>

            <header position="inside">
                <button name="action_print_invoice_template_dual"
                        type="object"
                        string="Imprimir"
                        class="btn-primary"
                        confirm="¿Confirma la impresión de esta factura? Asegúrese de que los montos en bolívares y dólares estén correctos antes de proceder."
                        attrs="{'invisible': [('move_type', 'not in', ['out_invoice', 'out_refund'])]}"/>
                <button name="action_delete_invoice"
                        type="object"
                        string="Eliminar"
                        class="btn btn-danger"
                        confirm="¿Está seguro de que desea eliminar esta factura?"
                        attrs="{'invisible': [('state', '!=', 'draft')]}"/>
            </header>
        </field>
    </record>

</odoo>
