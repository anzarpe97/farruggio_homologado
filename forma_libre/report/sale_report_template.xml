<odoo>
    <template id="report_quotation_template">
        <t t-name="forma_libre.report_quotation_template">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="doc">
                    <t t-set="tax_16" t-value="doc.env.context.get('report_tax_16', 0.0)"/>
                    <t t-set="tax_8" t-value="doc.env.context.get('report_tax_8', 0.0)"/>
                    <t t-set="tax_31" t-value="doc.env.context.get('report_tax_31', 0.0)"/>
                    <t t-set="page_size" t-value="13"/>
                    <t t-set="num_pages" t-value="(len(doc.order_line) + page_size - 1) // page_size"/>
                    <html lang="es">
                        <head>
                            <meta charset="UTF-8"/>
                            <meta http-equiv="Content-Type" content="text/html; charset=UTF-8"/>
                        </head>

                        <t t-foreach="range(num_pages)" t-as="page_index">
                            <div class="page" style="page-break-after: always; font-family: 'Open Sans', sans-serif; padding: 10mm;">
                                <!-- Encabezado empresa -->
                                <table style="width: 100%; font-size: 5px; margin-bottom: 15px;">
                                    <tr>
                                        <td style="text-align: center;">
                                            <p style="margin: 0; font-size: 11px;"><strong><t t-esc="doc.company_id.name or ''"/></strong></p>
                                            <p style="margin: 0;">R.I.F: <t t-esc="doc.company_id.vat or ''"/></p>
                                            <p style="margin: 0; line-height: 1.2;"><t t-esc="doc.company_id.partner_id.contact_address or ''"/></p>
                                            <p style="margin: 0;">Teléfono: <t t-esc="doc.company_id.phone or ''"/></p>
                                        </td>
                                    </tr>
                                </table>

                                <!-- Información cliente y presupuesto -->
                                <table style="width: 100%; font-size: 5px; margin-bottom: 5px;">
                                    <tr>
                                        <div style="margin-top: 0px;">
                                            <td style="width: 33%; vertical-align: top;">
                                                <p style="margin: 25px 0 0 0;"><strong>Cliente:</strong> <t t-esc="doc.partner_id.name or ''"/></p>
                                                <p style="margin: 0;"><strong>R.I.F:</strong> <t t-esc="doc.partner_id.vat or ''"/></p>
                                                <p style="margin: 0;"><strong>Teléfono:</strong> <t t-esc="doc.partner_id.phone or ''"/></p>
                                            </td>
                                        </div>
                                        <td style="width: 33%;"></td>
                                        <td style="width: 34%; text-align: right;">
                                            <p style="margin: 0;"><strong>Nro. Presupuesto:</strong> <t t-esc="doc.name or ''"/></p>
                                            <p style="margin: 0;"><strong>Fecha de Presupuesto:</strong> <t t-esc="doc.date_order.strftime('%d/%m/%Y') if doc.date_order else ''"/></p>
                                            <p style="margin: 0;"><strong>Término de Pago:</strong> <t t-esc="doc.payment_term_id.name or ''"/></p>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td colspan="3" style="padding-top: 10px;">
                                            <table style="width: 100%; font-size: 5px;">
                                                <tr>
                                                    <td style="width: 50%; padding-right: 10px;">
                                                        <p style="margin: 0;"><strong>Dirección Fiscal:</strong></p>
                                                        <div style="padding: 5px; min-height: 40px;">
                                                            <p style="margin: 0; line-height: 1.2;"><t t-esc="doc.partner_id.contact_address or ''"/></p>
                                                        </div>
                                                    </td>
                                                    <td style="width: 50%; padding-left: 10px;">
                                                        <p style="margin: 0;"><strong>Dirección de Entrega:</strong></p>
                                                        <div style="padding: 5px; min-height: 40px;">
                                                            <p style="margin: 0; line-height: 1.2;"><t t-esc="doc.partner_shipping_id.contact_address or ''"/></p>
                                                        </div>
                                                    </td>
                                                </tr>
                                            </table>
                                        </td>
                                    </tr>
                                </table>

                                <!-- Tabla de productos con columna de impuestos -->
                                <table style="width: 100%; font-size: 5px; margin-top: -30px; margin-bottom: 15px;">
                                    <thead>
                                        <tr style="border-bottom: 1px solid #ccc;">
                                            <th style="text-align: left; padding: 2px 5px;">Código</th>
                                            <th style="text-align: left; padding: 2px 5px;">Producto</th>
                                            <th style="text-align: right; padding: 2px 5px;">Cantidad</th>
                                            <th style="text-align: right; padding: 2px 5px;">Impuesto</th>
                                            <th style="text-align: right; padding: 2px 5px;">Precio</th>
                                            <th style="text-align: right; padding: 2px 5px;">Total</th>
                                            
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr t-foreach="doc.order_line[page_index * page_size : (page_index + 1) * page_size]" t-as="line">
                                            <td style="padding: 2px 5px;"><t t-esc="line.product_id.default_code or ''"/></td>
                                            <td style="padding: 2px 5px;"><t t-esc="line.product_id.name or ''"/></td>
                                            <td style="padding: 2px 5px; text-align: right;"><t t-esc="'%0.2f' % (line.product_uom_qty or 0.0)"/></td>
                                            <td style="padding: 2px 5px; text-align: right;">
                                                <t t-esc="', '.join([tax.name for tax in line.tax_id])"/>
                                            </td>
                                            <td style="padding: 2px 5px; text-align: right;"><t t-esc="'%0.2f' % (line.price_unit or 0.0)"/></td>
                                            <td style="padding: 2px 5px; text-align: right;"><t t-esc="'%0.2f' % (line.price_total or 0.0)"/></td>
                                        </tr>
                                    </tbody>
                                </table>

                                <!-- Condiciones y totales en cada página -->
                                <div style="position: fixed; top: 360px; left: 10px; width: 52%; font-size: 5px;">
                                    <p style="margin: 0;">Condiciones Especiales:</p>
                                    <p style="margin: 0; line-height: 1.2;">
                                        Este presupuesto es válido por <t t-esc="doc.validity_date or 'X'"/> días desde la fecha de emisión.
                                        Precios sujetos a cambios sin previo aviso.
                                    </p>
                                </div>
                                <div style="position: fixed; top: 360px; right: 10px; width: 48%; text-align: right; font-size: 5px;">
                                    <t t-if="tax_16 > 0">
                                        <p>IVA 16%:<t t-esc="'%0.2f' % tax_16"/></p>
                                    </t>
                                    <t t-if="tax_8 > 0">
                                        <p>IVA 8%:<t t-esc="'%0.2f' % tax_8"/></p>
                                    </t>
                                    <t t-if="tax_31 > 0">
                                        <p>IVA 31%:<t t-esc="'%0.2f' % tax_31"/></p>
                                    </t>
                                    <p>Subtotal:<t t-esc="'%0.2f' % (doc.amount_untaxed or 0.0)"/></p>
                                    <p>IVA Total: <t t-esc="'%0.2f' % (doc.amount_tax or 0.0)"/></p>
                                    <p>Total: <t t-esc="'%0.2f' % (doc.amount_total or 0.0)"/></p>
                                </div>
                            </div>
                        </t>
                    </html>
                </t>
            </t>
        </t>
    </template>
</odoo>
