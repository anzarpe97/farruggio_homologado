<odoo>
        <record id="fiscal_format" model="report.paperformat">
            <field name="name">Media Carta Fiscal</field>
            <field name="format">custom</field>
            <field name="page_height">210</field> <!-- Altura en mm (15.4 cm) -->
            <field name="page_width">154</field> <!-- Ancho en mm (21.59 cm para tamaño carta estándar) -->
            <field name="margin_top">24</field> <!-- Margen superior en mm -->
            <field name="margin_bottom">0</field> <!-- Margen inferior en mm (1.8 cm) -->
            <field name="margin_left">5</field> <!-- Margen izquierdo en mm -->
            <field name="margin_right">5</field> <!-- Margen derecho en mm -->
            <field name="orientation">Portrait</field> <!-- Orientación vertical -->
            <field name="dpi">90</field> <!-- Resolución -->
        </record>
</odoo>
