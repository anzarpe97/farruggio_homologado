<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista de formulario de factura - Agregar campos de costo -->
    <record id="view_move_form_inherit_cost" model="ir.ui.view">
        <field name="name">account.move.form.inherit.cost</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            
            <!-- Agregar el costo total en el grupo de totales -->
            <xpath expr="//field[@name='amount_total']" position="after">
                <field name="total_cost" 
                       groups="account.group_account_user"
                       attrs="{'invisible': [('move_type', 'not in', ['out_invoice', 'out_refund'])]}"/>
                <field name="total_cost_usd" 
                       groups="account.group_account_user"
                       attrs="{'invisible': [('move_type', 'not in', ['out_invoice', 'out_refund'])]}"/>
            </xpath>

            <!-- Agregar campos de costo en las líneas de factura -->
            <xpath expr="//field[@name='invoice_line_ids']/tree/field[@name='price_subtotal']" position="after">
                <field name="price_unit_ref" 
                       optional="hide"
                       groups="account.group_account_user"/>
                <field name="sale_line_cost" 
                       optional="hide"
                       groups="account.group_account_user"/>
                <field name="sale_line_cost_usd" 
                       optional="hide"
                       groups="account.group_account_user"/>
                <field name="total_cost" 
                       optional="hide"
                       groups="account.group_account_user"/>
                <field name="total_cost_usd" 
                       optional="hide"
                       groups="account.group_account_user"/>
                <field name="margin" 
                       optional="hide"
                       groups="account.group_account_user"/>
                <field name="margin_percent" 
                       optional="hide"
                       widget="percentage"
                       groups="account.group_account_user"/>
            </xpath>

        </field>
    </record>

    <!-- Vista de árbol/lista de facturas - Agregar costo total -->
    <record id="view_invoice_tree_inherit_cost" model="ir.ui.view">
        <field name="name">account.move.tree.inherit.cost</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_invoice_tree"/>
        <field name="arch" type="xml">
            
            <xpath expr="//field[@name='amount_total_signed']" position="after">
                <field name="total_cost" 
                       optional="hide"
                       groups="account.group_account_user"/>
                <field name="total_cost_usd" 
                       optional="hide"
                       groups="account.group_account_user"/>
            </xpath>

        </field>
    </record>

</odoo>
