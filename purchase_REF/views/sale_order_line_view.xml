<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="sale_order_line_form_inherit_ref" model="ir.ui.view">
            <field name="name">sale.order.line.form.inherit.ref</field>
            <field name="model">sale.order.line</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='order_line']/tree/field[@name='price_subtotal']" position="after">
                    <field name="ref" string="REF Subtotal" readonly="1"/>
                    <field name="ref_unit" string="REF Unit" digits="(16, 4)"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>