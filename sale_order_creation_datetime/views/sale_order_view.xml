<odoo>
    <!-- Vista Formulario -->
    <record id="view_order_form_inherit_creation_datetime" model="ir.ui.view">
        <field name="name">sale.order.form.creation.datetime</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="creation_datetime" string="Creado el: " readonly="1"/>
            </xpath>
        </field>
    </record>

    <!-- Vista Lista -->
    <record id="view_order_tree_inherit_creation_datetime" model="ir.ui.view">
        <field name="name">sale.order.tree.creation.datetime</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_quotation_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="creation_datetime" string="Creado el" readonly="1"/>
            </xpath>
        </field>
    </record>
</odoo>
