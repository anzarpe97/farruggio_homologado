<odoo>
    <!-- Para productos sin variantes -->
    <record id="view_product_template_margin_inherit" model="ir.ui.view">
        <field name="name">product.template.margin.inherit</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <!-- Hacer el campo list_price solo lectura -->
            <xpath expr="//field[@name='list_price']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>

            <xpath expr="//div[@name='standard_price_uom']" position="after">
                <field name="margin_percent" string="Margen de Utilidad (%)" groups="sales_team.group_sale_manager"/>
            </xpath>
        </field>
    </record>

    <!-- Para productos con variantes -->
    <record id="view_product_template_margin_normal_inherit" model="ir.ui.view">
        <field name="name">product.template.margin.normal.inherit</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <!-- Hacer el campo list_price solo lectura -->
            <xpath expr="//field[@name='list_price']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>
        
            <xpath expr="//div[@name='standard_price_uom']" position="after">
                <field name="margin_percent" string="Margen de Utilidad (%)" groups="sales_team.group_sale_manager"/>
            </xpath>
        </field>
    </record>

    <record id="view_product_template_tree_margin_inherit" model="ir.ui.view">
        <field name="name">product.template.tree.margin.inherit</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='list_price']" position="after">
                <field name="computed_margin_percent" string="Margen (%)" groups="sales_team.group_sale_manager"/>
            </xpath>
        </field>
    </record>

    <!-- Para categorías -->
    <record id="view_product_category_margin_inherit" model="ir.ui.view">
        <field name="name">product.category.margin.inherit</field>
        <field name="model">product.category</field>
        <field name="inherit_id" ref="product.product_category_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='parent_id']" position="after">
                <field name="margin_percent" string="Margen de Utilidad (%)" groups="sales_team.group_sale_manager"/>
            </xpath>
        </field>
    </record>
</odoo>
