    <odoo>
        <record id="view_order_form_inherit_pdvsa_flag" model="ir.ui.view">
            <field name="name">sale.order.form.pdvsa.flag</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <!-- Campo oculto -->
                <xpath expr="//sheet" position="inside">
                    <field name="is_pdvsa" invisible="1"/>
                </xpath>

                <!-- Botón -->
                <xpath expr="//header" position="inside">
                    <button name="action_open_pdvsa_mass_invoice_wizard"
                        type="object"
                        string="Generar Factura PDVSA"
                        class="btn btn-primary"
                        attrs="{'invisible': [('is_pdvsa', '=', False)]}"/>
                </xpath>
                
                <!-- <xpath expr="//div[@class='oe_button_box']" position="inside">
                    <button name="action_view_pdvsa_invoice"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-file-invoice"
                            attrs="{'invisible': [('pdvsa_invoice_count', '=', 0)]}">
                        <field name="pdvsa_invoice_count" widget="statinfo" string="Factura PDVSA"/>
                    </button>
                </xpath> -->
            </field>
        </record>
    </odoo>
