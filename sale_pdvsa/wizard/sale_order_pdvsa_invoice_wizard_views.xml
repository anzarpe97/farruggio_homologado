<odoo>
    <data>

        <!-- Vista del wizard -->
        <record id="view_sale_order_pdvsa_mass_invoice_form" model="ir.ui.view">
            <field name="name">sale.order.pdvsa.mass.invoice.form</field>
            <field name="model">sale.order.pdvsa.mass.invoice.wizard</field>
            <field name="arch" type="xml">
                <form string="Generar Factura PDVSA">
                    <group>
                        <field name="order_ids" widget="many2many_tags"/>
                    </group>
                    <footer>
                        <button string="Confirmar" type="object" name="action_confirm" class="btn-primary"/>
                        <button string="Cancelar" special="cancel" class="btn-secondary"/>
                    </footer>
                </form>
            </field>
        </record>

        <!-- Acción del wizard -->
        <record id="action_sale_order_pdvsa_mass_invoice_wizard" model="ir.actions.act_window">
            <field name="name">Generar Factura PDVSA</field>
            <field name="res_model">sale.order.pdvsa.mass.invoice.wizard</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_sale_order_pdvsa_mass_invoice_form"/>
            <field name="target">new</field>
        </record>

    </data>
</odoo>
