<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <data >
        <!-- Add you code here -->
        <record id="base.VEF" model="res.currency">
            <field name="name">Bs.</field>
            <field name="symbol">Bs.</field>
            <field name="decimal_places">2</field>
        </record>

        <record id="update_sale_price_product" model="ir.cron">
            <field name="name">Actualizar Producto </field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="user_id" ref="base.user_root"/>
            <field name="priority">2</field>
            <field name="state">code</field>
            <field name="model_id" ref="vzla_currency_rate.model_res_currency_rate_server" />
            <field name="code">model._cron_update_product()</field>
            <field name="active" eval="True"/>
        </record>

        <record id="ir_cron_update_sell_rate" model="ir.cron">
            <field name="name">Actualizar Sell Rate</field>
            <field name="model_id" ref="base.model_res_currency_rate"/> <!-- Modelo res.currency.rate -->
            <field name="state">code</field>
            <field name="code">
                model.update_sell_rate_cron()
            </field>
            <field name="interval_number">1</field> <!-- Intervalo: 1 día -->
            <field name="interval_type">days</field> <!-- Frecuencia diaria -->
            <field name="numbercall">-1</field> <!-- Ejecuciones ilimitadas -->
            <field name="doall" eval="False"/> <!-- No ejecutar tareas pendientes -->
            <field name="user_id" ref="base.user_root"/> <!-- Usuario administrador -->
            <field name="active" eval="True"/> <!-- Activo por defecto -->
        </record>

        <record id="ir_cron_update_pricelist_items" model="ir.cron">
            <field name="name">Actualizar precios de lista automáticamente</field>
            <field name="model_id" ref="model_product_pricelist"/>
            <field name="state">code</field>
            <field name="code">model.update_pricelist_items()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
        </record>

       
        <record id="ir_cron_update_rate" model="ir.cron">
            <field name="name">Actualizar Tasas de Cambio</field>
            <field name="model_id" ref="vzla_currency_rate.model_res_currency_rate_server"/> <!-- Modelo correcto -->
            <field name="state">code</field>
            <field name="code">model._cron_update_rate()</field> <!-- Usando la función existente -->
            <field name="interval_number">1</field> <!-- Ejecutar cada 1 día -->
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field> <!-- Número ilimitado de llamadas -->
            <field name="user_id" ref="base.user_root"/> <!-- Usuario administrador -->
            <field name="active" eval="True"/> <!-- Activo por defecto -->
        </record>


    </data>
</odoo>