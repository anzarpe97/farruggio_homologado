<odoo>
    <record id="group_cattle_purchase" model="res.groups">
        <field name="name">Gestión de Compras de Reses</field>
        <field name="category_id" ref="purchase.group_purchase_manager"/> 
        <field name="comment">Este grupo permite a los usuarios gestionar compras de reses.</field>
    </record>

    <record id="group_cattle_reception" model="res.groups">
        <field name="name">Recepción de Reses</field>
        <field name="category_id" ref="base.module_category_inventory"/>
        <field name="comment">Este grupo permite a los usuarios gestionar la recepción de reses.</field>
    </record>

    <!-- Grupo de acceso general para los usuarios de compras -->
    <record id="purchase_cattle_access_rule" model="ir.model.access">
        <field name="name">purchase.cattle.line access</field>
        <field name="model_id" ref="model_purchase_cattle_line"/>
        <field name="group_id" ref="purchase.group_purchase_user"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="1"/>
    </record>
</odoo>
