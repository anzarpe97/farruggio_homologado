<odoo>
    <record id="view_cattle_product_wizard" model="ir.ui.view">
        <field name="name">cattle.product.wizard.form</field>
        <field name="model">cattle.product.wizard</field>
        <field name="arch" type="xml">
            <form string="Seleccionar Reses a Recibir">
                <group>
                    <field name="cattle_product_ids" widget="many2many_tags"/>
                </group>
                <footer>
                    <button string="Confirmar" type="object" name="action_confirm" class="oe_highlight"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>

